@model IEnumerable<PRESAM.Application.DTOs.OrderDto>
@{
    ViewData["Title"] = "All Orders";
}
<div class="container">
    <h2 style="margin-bottom: 30px;">All Orders</h2>
    <div class="premium-card">
        <div style="display: grid; gap: 15px;">
            @foreach (var order in Model)
            {
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid var(--border);">
                    <div><strong>#@order.OrderNumber</strong><br /><small>@order.OrderDate.ToString("MMM dd, yyyy")</small></div>
                    <div>₦@order.TotalAmount.ToString("N0")</div>
                    <div><span style="background: var(--accent); padding: 3px 10px; border-radius: 20px;">@order.Status</span></div>
                    <a href="/Admin/OrderDetails/@order.Id" class="btn-premium" style="padding: 5px 15px;">View</a>
                </div>
            }
        </div>
    </div>
</div>