@model PRESAM.Application.DTOs.CategoryDto

@{
    ViewData["Title"] = "Add Category";
}

<div class="container" style="max-width: 600px;">
    <div class="premium-card">
        <h2>Add New Category</h2>
        
        @if (TempData["Error"] != null)
        {
            <div class="alert-error">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="form-group">
                <label>Category Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            
            <div class="form-group">
                <label>Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://via.placeholder.com/300" />
            </div>
            
            <button type="submit" class="btn-primary">Create Category</button>
            <a href="/Admin/Dashboard" class="btn-secondary">Cancel</a>
        </form>
    </div>
</div>

<style>
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; }
    .form-control { width: 100%; padding: 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 12px; color: var(--text-primary); }
    .btn-primary { background: var(--accent); color: black; padding: 12px 24px; border: none; border-radius: 12px; cursor: pointer; font-weight: 600; }
    .btn-secondary { display: inline-block; background: var(--bg-primary); border: 1px solid var(--border); color: var(--text-secondary); padding: 12px 24px; border-radius: 12px; text-decoration: none; margin-left: 10px; }
    .alert-error { background: rgba(231,76,60,0.1); border: 1px solid #e74c3c; color: #e74c3c; padding: 12px; border-radius: 12px; margin-bottom: 20px; }
</style>