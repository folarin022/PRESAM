@model PRESAM.Application.DTOs.ProductDto

@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as IEnumerable<PRESAM.Application.DTOs.CategoryDto>;
}

<div class="container" style="max-width: 700px;">
    <div class="premium-card">
        <h2>Edit Product</h2>
        
        @if (TempData["Error"] != null)
        {
            <div class="alert-error">@TempData["Error"]</div>
        }

        <form method="post" asp-action="EditProduct">
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label>Product Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            
            <div class="row">
                <div class="col">
                    <label>Price (₦)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="col">
                    <label>Stock Quantity</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" required />
                </div>
            </div>
            
            <div class="form-group">
                <label>Image URL</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://via.placeholder.com/300" />
            </div>
            
            <div class="form-group">
                <label>Category</label>
                <select asp-for="CategoryId" class="form-control" required>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="checkbox-label">
                    <input asp-for="IsActive" type="checkbox" />
                    Active (Show on website)
                </label>
            </div>
            
            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/Product/Details/@Model.Id" class="btn-secondary">Cancel</a>
        </form>
    </div>
</div>

<style>
    .premium-card {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 30px;
        border: 1px solid var(--border);
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
    }

    .row {
        display: flex;
        gap: 20px;
        margin-bottom: 0;
    }

    .col {
        flex: 1;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

        .checkbox-label input {
            width: 18px;
            height: 18px;
        }

    .btn-primary {
        background: var(--accent);
        color: black;
        padding: 12px 28px;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-secondary {
        display: inline-block;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        padding: 12px 28px;
        border-radius: 12px;
        text-decoration: none;
        margin-left: 10px;
    }

    .alert-error {
        background: rgba(231,76,60,0.1);
        border: 1px solid #e74c3c;
        color: #e74c3c;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 20px;
    }
</style>