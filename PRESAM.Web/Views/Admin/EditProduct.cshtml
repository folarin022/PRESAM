@model PRESAM.Application.DTOs.ProductDto

@{
    ViewData["Title"] = "Edit Product";
    var categories = ViewBag.Categories as IEnumerable<PRESAM.Application.DTOs.CategoryDto>;
}

<div class="container" style="max-width: 700px;">
    <div class="premium-card">
        <h2>Edit Product</h2>
        
        @if (TempData["Error"] != null)
        {
            <div class="alert-error">@TempData["Error"]</div>
        }

        <form method="post" asp-action="EditProduct" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label>Product Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            
            <div class="form-group">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            
            <div class="row">
                <div class="col">
                    <label>Price (₦)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="col">
                    <label>Stock Quantity</label>
                    <input asp-for="StockQuantity" class="form-control" type="number" required />
                </div>
            </div>

            <!-- Current Images -->
            <div class="current-images">
                <label>Current Images</label>
                <div class="image-grid">
                    <div class="current-image-card">
                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/products/placeholder.jpg" : Model.ImageUrl)" />
                        <span>Image 1</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl2))
                    {
                        <div class="current-image-card">
                            <img src="@Model.ImageUrl2" />
                            <span>Image 2</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ImageUrl3))
                    {
                        <div class="current-image-card">
                            <img src="@Model.ImageUrl3" />
                            <span>Image 3</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Upload New Images -->
            <div class="form-group">
                <label>New Image 1 (leave empty to keep current)</label>
                <div class="image-upload-area" id="imageUploadArea1">
                    <label for="productImage1" class="upload-label">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Click to upload new image 1</p>
                    </label>
                    <input type="file" name="ProductImage" accept="image/*" id="productImage1" style="display: none;" onchange="previewImage(1)" />
                    <div class="image-preview" id="imagePreview1" style="display: none;">
                        <img id="previewImg1" src="#" alt="Preview" />
                        <button type="button" class="remove-image" onclick="removeImage(1)"><i class="fas fa-times"></i></button>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>New Image 2 (leave empty to keep current)</label>
                <div class="image-upload-area" id="imageUploadArea2">
                    <label for="productImage2" class="upload-label">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Click to upload new image 2</p>
                    </label>
                    <input type="file" name="ProductImage2" accept="image/*" id="productImage2" style="display: none;" onchange="previewImage(2)" />
                    <div class="image-preview" id="imagePreview2" style="display: none;">
                        <img id="previewImg2" src="#" alt="Preview" />
                        <button type="button" class="remove-image" onclick="removeImage(2)"><i class="fas fa-times"></i></button>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>New Image 3 (leave empty to keep current)</label>
                <div class="image-upload-area" id="imageUploadArea3">
                    <label for="productImage3" class="upload-label">
                        <i class="fas fa-cloud-upload-alt"></i>
                        <p>Click to upload new image 3</p>
                    </label>
                    <input type="file" name="ProductImage3" accept="image/*" id="productImage3" style="display: none;" onchange="previewImage(3)" />
                    <div class="image-preview" id="imagePreview3" style="display: none;">
                        <img id="previewImg3" src="#" alt="Preview" />
                        <button type="button" class="remove-image" onclick="removeImage(3)"><i class="fas fa-times"></i></button>
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                <label>Category</label>
                <select asp-for="CategoryId" class="form-control" required>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="checkbox-label">
                    <input asp-for="IsActive" type="checkbox" />
                    Active (Show on website)
                </label>
            </div>
            
            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/Product/Details/@Model.Id" class="btn-secondary">Cancel</a>
        </form>
    </div>
</div>

<style>
    .premium-card {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 30px;
        border: 1px solid var(--border);
    }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; }
    .form-control {
        width: 100%;
        padding: 12px;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
    }
    .row { display: flex; gap: 20px; margin-bottom: 0; }
    .col { flex: 1; }
    .checkbox-label { display: flex; align-items: center; gap: 8px; cursor: pointer; }
    .checkbox-label input { width: 18px; height: 18px; }

    /* Current Images */
    .current-images { margin-bottom: 20px; }
    .current-images label { display: block; margin-bottom: 10px; font-weight: 500; }
    .image-grid { display: flex; gap: 12px; flex-wrap: wrap; }
    .current-image-card {
        width: 100px;
        text-align: center;
    }
    .current-image-card img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid var(--border);
    }
    .current-image-card span {
        font-size: 11px;
        color: var(--text-secondary);
        margin-top: 4px;
        display: block;
    }

    /* Upload */
    .image-upload-area {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        background: var(--bg-primary);
        cursor: pointer;
        transition: 0.2s;
    }
    .image-upload-area:hover { border-color: var(--accent); }
    .upload-label { cursor: pointer; display: block; }
    .upload-label i { font-size: 32px; color: var(--accent); }
    .upload-label p { margin-top: 5px; font-size: 13px; }
    .image-preview { position: relative; display: flex; justify-content: center; margin-top: 10px; }
    .image-preview img { max-width: 100%; max-height: 180px; border-radius: 10px; }
    .remove-image {
        position: absolute; top: -10px; right: -10px;
        width: 28px; height: 28px;
        background: #e74c3c; color: white;
        border: none; border-radius: 50%; cursor: pointer;
    }

    .btn-primary {
        background: var(--accent); color: black;
        padding: 12px 28px; border: none; border-radius: 12px;
        cursor: pointer; font-weight: 600;
    }
    .btn-secondary {
        display: inline-block;
        background: var(--bg-primary); border: 1px solid var(--border);
        color: var(--text-secondary); padding: 12px 28px;
        border-radius: 12px; text-decoration: none; margin-left: 10px;
    }
    .alert-error {
        background: rgba(231,76,60,0.1); border: 1px solid #e74c3c;
        color: #e74c3c; padding: 12px; border-radius: 12px; margin-bottom: 20px;
    }
</style>

<script>
    function previewImage(num) {
        const input = document.getElementById('productImage' + num);
        const preview = document.getElementById('imagePreview' + num);
        const previewImg = document.getElementById('previewImg' + num);
        const uploadLabel = document.querySelector('#imageUploadArea' + num + ' .upload-label');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                preview.style.display = 'flex';
                uploadLabel.style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
    function removeImage(num) {
        const input = document.getElementById('productImage' + num);
        const preview = document.getElementById('imagePreview' + num);
        const uploadLabel = document.querySelector('#imageUploadArea' + num + ' .upload-label');
        input.value = '';
        preview.style.display = 'none';
        uploadLabel.style.display = 'block';
    }
</script>