@model PRESAM.Application.DTOs.OrderDto
@{
    ViewData["Title"] = "Order Details";
}
<div class="container" style="max-width: 700px;">
    <div class="premium-card">
        <h2>Order #@Model.OrderNumber</h2>
        <hr>
        <div style="display: grid; gap: 10px; margin-bottom: 20px;">
            <div><strong>Date:</strong> @Model.OrderDate</div>
            <div><strong>Status:</strong> <span style="background: var(--accent); padding: 3px 10px; border-radius: 20px;">@Model.Status</span></div>
            <div><strong>Shipping:</strong> @Model.ShippingAddress</div>
            <div><strong>Payment:</strong> @Model.PaymentMethod</div>
        </div>
        <h3>Items</h3>
        @foreach (var item in Model.Items)
        {
            <div style="display: flex; justify-content: space-between; padding: 5px 0;">@item.ProductName x @item.Quantity <span>₦@item.TotalPrice.ToString("N0")</span></div>
        }
        <hr><div style="display: flex; justify-content: space-between; font-weight: bold;"><span>Total</span><span>₦@Model.TotalAmount.ToString("N0")</span></div>
        <form action="/Admin/UpdateOrderStatus" method="post" style="margin-top: 20px;">
            <input type="hidden" name="orderId" value="@Model.Id" />
            <select name="status" class="premium-input" style="width: auto; display: inline-block;">
                <option value="Pending">Pending</option><option value="Processing">Processing</option><option value="Shipped">Shipped</option><option value="Delivered">Delivered</option><option value="Cancelled">Cancelled</option>
            </select>
            <button type="submit" class="btn-premium">Update Status</button>
        </form>
        <a href="/Admin/Orders" class="btn-premium" style="display: inline-block; margin-top: 15px;">Back to Orders</a>
    </div>
</div>