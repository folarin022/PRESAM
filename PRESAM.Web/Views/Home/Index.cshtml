@model IEnumerable<PRESAM.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = "PRESAM - Premium Shopping";
    var categories = ViewBag.Categories as IEnumerable<PRESAM.Application.DTOs.CategoryDto>;
}
<div class="hero" style="background: linear-gradient(135deg, var(--accent) 0%, #1a1a2e 100%); padding: 80px 20px; text-align: center; margin-bottom: 50px;">
    <h1 style="font-size: 56px; margin-bottom: 15px;">PRESAM</h1>
    <p style="font-size: 20px; opacity: 0.9;">Premium products, exceptional quality</p>
    @if (!User.Identity.IsAuthenticated)
    {
        <div style="margin-top: 30px;"><a href="/Account/Login" class="btn-premium">Start Shopping</a></div>
    }
</div>
<div class="container">
    @if (!User.Identity.IsAuthenticated)
    {
        <div style="background: var(--bg-card); border-left: 4px solid var(--accent); padding: 15px; border-radius: 10px; margin-bottom: 30px; text-align: center;">
            <i class="fas fa-lock"></i> Please <a href="/Account/Login" style="color: var(--accent);">login</a> or <a href="/Account/Register" style="color: var(--accent);">register</a> to start shopping
        </div>
    }
    @if (categories != null && categories.Any())
    {
        <h2 style="margin-bottom: 25px;">Shop by Category</h2>
        <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 50px;">
            @foreach (var cat in categories)
            {
                <a href="/Product/ByCategory/@cat.Id" style="text-decoration: none;">
                    <div style="background: var(--bg-card); padding: 12px 25px; border-radius: 50px; border: 1px solid var(--border);">
                        <i class="fas fa-tag" style="color: var(--accent);"></i> @cat.Name <span style="color: var(--text-secondary);">(@cat.ProductCount)</span>
                    </div>
                </a>
            }
        </div>
    }
    <h2 style="margin-bottom: 25px;">Featured Products</h2>
    @if (Model != null && Model.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
            @foreach (var product in Model.Take(8))
            {
                <div class="premium-card">
                    <img src="@product.ImageUrl" style="width: 100%; height: 240px; object-fit: cover; border-radius: 15px; margin-bottom: 15px;">
                    <h3>@product.Name</h3>
                    <p style="color: var(--text-secondary); font-size: 13px;">@product.CategoryName</p>
                    <p style="font-size: 24px; font-weight: 700; color: var(--accent); margin: 10px 0;">₦@product.Price.ToString("N0")</p>
                    <a href="/Product/Details/@product.Id" class="btn-premium" style="display: inline-block; padding: 10px 20px; font-size: 14px;">View Details</a>
                </div>
            }
        </div>
    }
    else
    {
        <p style="text-align: center;">No products available yet.</p>
    }
</div>