@{
    ViewData["Title"] = "Forgot Password";
}
<div class="container" style="max-width: 450px;">
    <div class="premium-card">
        <h2 style="text-align: center; margin-bottom: 20px;">Reset Password</h2>
        <p style="text-align: center; margin-bottom: 20px;">Enter your email to receive reset link</p>
        <form method="post">
            <input type="email" name="email" class="premium-input" placeholder="Email address" required />
            <button type="submit" class="btn-premium" style="width: 100%; margin-top: 20px;">Send Reset Link</button>
        </form>
        <p style="text-align: center; margin-top: 20px;"><a href="/Account/Login" style="color: var(--accent);">Back to Login</a></p>
    </div>
</div>