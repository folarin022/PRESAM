@model PRESAM.Application.DTOs.LoginDto
@{
    ViewData["Title"] = "Sign In";
}

<style>
    .login-page {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
    }
</style>

<div class="login-page">
    <div class="container" style="max-width: 450px; margin: 0 auto;">
        <div class="premium-card" style="text-align: center; padding: 45px 40px;">
            <i class="fas fa-gem" style="font-size: 55px; color: var(--accent); margin-bottom: 15px;"></i>
            <h2 style="margin-bottom: 8px;">Welcome Back</h2>
            <p style="color: var(--text-secondary); margin-bottom: 30px;">Sign in to your account</p>
            
            <form method="post">
                <div asp-validation-summary="ModelOnly" style="color: var(--danger); margin-bottom: 15px;"></div>
                
                <input asp-for="Email" class="premium-input" placeholder="Email address" style="margin-bottom: 15px;" />
                <span asp-validation-for="Email" style="color: var(--danger); font-size: 12px;"></span>
                
                <input asp-for="Password" type="password" class="premium-input" placeholder="Password" style="margin-bottom: 15px;" />
                <span asp-validation-for="Password" style="color: var(--danger); font-size: 12px;"></span>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <input asp-for="RememberMe" style="width: 16px; height: 16px;" />
                        <span style="font-size: 13px;">Remember me</span>
                    </label>
                    <a href="/Account/ForgotPassword" style="color: var(--accent); text-decoration: none; font-size: 13px;">Forgot password?</a>
                </div>
                
                <button type="submit" class="btn-premium" style="width: 100%; padding: 14px; font-size: 16px;">Sign In</button>
            </form>
            
            <p style="margin-top: 25px; font-size: 14px;">
                Don't have an account?
                <a href="/Account/Register" style="color: var(--accent); text-decoration: none; font-weight: 600;">Join Now</a>
            </p>
        </div>
    </div>
</div>