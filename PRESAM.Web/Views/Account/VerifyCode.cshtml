@model PRESAM.Application.DTOs.VerifyCodeDto
@{
    ViewData["Title"] = "Verify Your Account";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    .verify-page {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
    }
    .code-inputs {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin: 30px 0;
    }
    .code-input {
        width: 60px;
        height: 70px;
        text-align: center;
        font-size: 28px;
        font-weight: 600;
        background: var(--bg-primary);
        border: 2px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: monospace;
    }
    .code-input:focus {
        outline: none;
        border-color: var(--accent);
    }
    .timer {
        font-size: 14px;
        color: var(--text-secondary);
        margin-top: 15px;
    }
    .timer span {
        color: var(--accent);
        font-weight: bold;
        font-size: 18px;
    }
</style>

<div class="verify-page">
    <div class="container" style="max-width: 500px; margin: 0 auto;">
        <div class="premium-card" style="text-align: center; padding: 45px 40px;">
            <i class="fas fa-shield-alt" style="font-size: 55px; color: var(--accent); margin-bottom: 15px;"></i>
            <h2 style="margin-bottom: 8px;">Verify Your Account</h2>
            <p style="color: var(--text-secondary); margin-bottom: 10px;">
                We sent a 6-digit code to <strong>@Model.Email</strong>
            </p>
            <p style="color: var(--text-secondary); font-size: 13px;">
                Please enter the code below to verify your account
            </p>
            
            <form method="post" id="verifyForm">
                <input type="hidden" asp-for="Email" />
                
                <div class="code-inputs">
                    <input type="text" maxlength="1" class="code-input" id="code1" onkeyup="moveToNext(this, 'code2')" />
                    <input type="text" maxlength="1" class="code-input" id="code2" onkeyup="moveToNext(this, 'code3')" />
                    <input type="text" maxlength="1" class="code-input" id="code3" onkeyup="moveToNext(this, 'code4')" />
                    <input type="text" maxlength="1" class="code-input" id="code4" onkeyup="moveToNext(this, 'code5')" />
                    <input type="text" maxlength="1" class="code-input" id="code5" onkeyup="moveToNext(this, 'code6')" />
                    <input type="text" maxlength="1" class="code-input" id="code6" onkeyup="moveToNext(this, null)" />
                </div>
                
                <input type="hidden" name="Code" id="fullCode" />
                
                <div asp-validation-summary="ModelOnly" style="color: var(--danger); margin-bottom: 15px;"></div>
                
                <button type="submit" class="btn-premium" style="width: 100%; padding: 14px; font-size: 16px;">Verify Account</button>
            </form>
            
            <div class="timer">
                <p>Code expires in: <span id="timer">10:00</span></p>
                <button type="button" id="resendBtn" onclick="resendCode()" style="background: none; border: none; color: var(--accent); cursor: pointer; display: none;">Didn't get code? Resend</button>
            </div>
            
            <p style="margin-top: 25px; font-size: 13px; color: var(--text-secondary);">
                <i class="fas fa-envelope"></i> Check your email inbox
            </p>
        </div>
    </div>
</div>

<script>
    let timerInterval;
    let timeLeft = 600; // 10 minutes in seconds
    
    function moveToNext(current, nextId) {
        if (current.value.length === 1 && nextId) {
            document.getElementById(nextId).focus();
        }
        updateFullCode();
    }
    
    function updateFullCode() {
        let code = '';
        for (let i = 1; i <= 6; i++) {
            let val = document.getElementById('code' + i).value;
            code += val;
        }
        document.getElementById('fullCode').value = code;
        
        if (code.length === 6) {
            document.getElementById('verifyForm').submit();
        }
    }
    
    function startTimer() {
        timerInterval = setInterval(function() {
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                document.getElementById('timer').innerHTML = 'Expired';
                document.getElementById('resendBtn').style.display = 'inline-block';
            } else {
                timeLeft--;
                let minutes = Math.floor(timeLeft / 60);
                let seconds = timeLeft % 60;
                document.getElementById('timer').innerHTML = 
                    `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }
        }, 1000);
    }
    
    function resendCode() {
        const email = '@Model.Email';
        fetch('/Account/ResendCode', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(email)
        }).then(response => {
            if (response.ok) {
                alert('New code sent to your email!');
                timeLeft = 600;
                startTimer();
                document.getElementById('resendBtn').style.display = 'none';
                
                // Clear inputs
                for (let i = 1; i <= 6; i++) {
                    document.getElementById('code' + i).value = '';
                }
                document.getElementById('code1').focus();
            } else {
                alert('Failed to resend code. Please try again.');
            }
        });
    }
    
    startTimer();
    
    // Paste code support
    document.querySelectorAll('.code-input').forEach((input, index, inputs) => {
        input.addEventListener('paste', function(e) {
            e.preventDefault();
            const paste = (e.clipboardData || window.clipboardData).getData('text');
            const numbers = paste.replace(/\D/g, '').split('');
            
            for (let i = 0; i < numbers.length && i + index < 6; i++) {
                inputs[index + i].value = numbers[i];
            }
            updateFullCode();
            
            if (numbers.length > 0) {
                const nextIndex = Math.min(index + numbers.length, 5);
                inputs[nextIndex].focus();
            }
        });
    });
</script>
