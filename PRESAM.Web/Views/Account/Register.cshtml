@model PRESAM.Application.DTOs.RegisterDto

@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PRESAM - Create Account</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
            :root {
                --bg-primary: #0a0a0a;
                --bg-card: #1a1a1a;
                --text-primary: #ffffff;
                --text-secondary: #a0a0a0;
                --accent: #c6a43f;
                --accent-hover: #d4b856;
                --border: #2a2a2a;
                --danger: #e74c3c;
                --success: #2ecc71;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Plus Jakarta Sans', sans-serif;
                background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .register-container {
                width: 100%;
                max-width: 550px;
                margin: 30px 20px;
            }

            .register-card {
                background: var(--bg-card);
                border-radius: 30px;
                padding: 45px 40px;
                border: 1px solid var(--border);
            }

            .logo {
                text-align: center;
                margin-bottom: 30px;
            }

                .logo i {
                    font-size: 55px;
                    color: var(--accent);
                    margin-bottom: 15px;
                }

                .logo h1 {
                    font-size: 32px;
                    font-weight: 700;
                    background: linear-gradient(135deg, var(--accent) 0%, #e8c97a 100%);
                    -webkit-background-clip: text;
                    background-clip: text;
                    color: transparent;
                }

                .logo p {
                    color: var(--text-secondary);
                    font-size: 14px;
                    margin-top: 8px;
                }

            .welcome-text {
                text-align: center;
                margin-bottom: 30px;
            }

                .welcome-text h2 {
                    font-size: 24px;
                    margin-bottom: 8px;
                }

                .welcome-text p {
                    color: var(--text-secondary);
                    font-size: 14px;
                }

            .input-group {
                margin-bottom: 18px;
            }

                .input-group label {
                    display: block;
                    font-size: 13px;
                    font-weight: 500;
                    margin-bottom: 8px;
                    color: var(--text-primary);
                }

                .input-group input {
                    width: 100%;
                    padding: 14px 16px;
                    background: var(--bg-primary);
                    border: 1px solid var(--border);
                    border-radius: 16px;
                    font-size: 14px;
                    color: var(--text-primary);
                    font-family: 'Plus Jakarta Sans', sans-serif;
                    transition: all 0.3s;
                }

                    .input-group input:focus {
                        outline: none;
                        border-color: var(--accent);
                    }

                    .input-group input::placeholder {
                        color: var(--text-secondary);
                    }

            .row {
                display: flex;
                gap: 15px;
            }

                .row .input-group {
                    flex: 1;
                }

            .btn-register {
                width: 100%;
                padding: 14px;
                background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
                border: none;
                border-radius: 50px;
                color: black;
                font-size: 16px;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s;
                margin-top: 10px;
                margin-bottom: 20px;
            }

                .btn-register:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 25px rgba(198, 164, 63, 0.3);
                }

            .login-link {
                text-align: center;
                font-size: 14px;
                color: var(--text-secondary);
            }

                .login-link a {
                    color: var(--accent);
                    text-decoration: none;
                    font-weight: 600;
                }

                    .login-link a:hover {
                        text-decoration: underline;
                    }

            .error-message {
                background: rgba(231, 76, 60, 0.1);
                border: 1px solid var(--danger);
                color: var(--danger);
                padding: 12px;
                border-radius: 12px;
                font-size: 13px;
                margin-bottom: 20px;
            }

            .field-validation-error {
                color: var(--danger);
                font-size: 12px;
                margin-top: 5px;
                display: block;
            }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="logo">
                <i class="fas fa-gem"></i>
                <h1>PRESAM</h1>
                <p>Join our shopping family</p>
            </div>

            <div class="welcome-text">
                <h2>Create Account</h2>
                <p>Fill in your details below</p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="error-message">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <span>@error.ErrorMessage</span>
                        <br />
                    }
                </div>
            }

            <form method="post">
                <div class="row">
                    <div class="input-group">
                        <label>First Name</label>
                        <input asp-for="FirstName" placeholder="John" />
                        <span asp-validation-for="FirstName" class="field-validation-error"></span>
                    </div>

                    <div class="input-group">
                        <label>Last Name</label>
                        <input asp-for="LastName" placeholder="Doe" />
                        <span asp-validation-for="LastName" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="input-group">
                    <label>Email Address</label>
                    <input asp-for="Email" type="email" placeholder="john@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="input-group">
                    <label>Phone Number</label>
                    <input asp-for="PhoneNumber" placeholder="+234 123 456 7890" />
                    <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                </div>

                <div class="input-group">
                    <label>Address</label>
                    <input asp-for="Address" placeholder="Your home address" />
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>

                <div class="row">
                    <div class="input-group">
                        <label>Password</label>
                        <input asp-for="Password" type="password" placeholder="Create a password" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>

                    <div class="input-group">
                        <label>Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your password" />
                        <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-register">Create Account</button>

                <div class="login-link">
                    Already have an account? <a href="/Account/Login">Sign In</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>