@model PRESAM.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Create Account";
}
<div class="container" style="max-width: 500px;">
    <div class="premium-card">
        <h2 style="text-align: center; margin-bottom: 20px;">Create Account</h2>
        <form method="post">
            <div asp-validation-summary="ModelOnly" style="color: var(--danger); margin-bottom: 15px;"></div>
            <div style="display: flex; gap: 15px;">
                <div style="flex:1;"><input asp-for="FirstName" class="premium-input" placeholder="First name" /></div>
                <div style="flex:1;"><input asp-for="LastName" class="premium-input" placeholder="Last name" /></div>
            </div>
            <span asp-validation-for="FirstName" style="color: var(--danger); font-size: 12px;"></span>
            <input asp-for="Email" class="premium-input" placeholder="Email address" style="margin-top: 15px;" />
            <span asp-validation-for="Email" style="color: var(--danger); font-size: 12px;"></span>
            <input asp-for="PhoneNumber" class="premium-input" placeholder="Phone number" style="margin-top: 15px;" />
            <input asp-for="Address" class="premium-input" placeholder="Address" style="margin-top: 15px;" />
            <input asp-for="Password" type="password" class="premium-input" placeholder="Password" style="margin-top: 15px;" />
            <span asp-validation-for="Password" style="color: var(--danger); font-size: 12px;"></span>
            <input asp-for="ConfirmPassword" type="password" class="premium-input" placeholder="Confirm password" style="margin-top: 15px;" />
            <span asp-validation-for="ConfirmPassword" style="color: var(--danger); font-size: 12px;"></span>
            <button type="submit" class="btn-premium" style="width: 100%; margin-top: 25px;">Create Account</button>
        </form>
        <p style="text-align: center; margin-top: 20px;">Already have an account? <a href="/Account/Login" style="color: var(--accent);">Sign In</a></p>
    </div>
</div>