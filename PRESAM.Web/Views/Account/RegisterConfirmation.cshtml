@{
    ViewData["Title"] = "Check Your Email";
}
<div class="container" style="max-width: 500px;">
    <div class="premium-card" style="text-align: center;">
        <i class="fas fa-envelope" style="font-size: 60px; color: var(--accent); margin-bottom: 20px;"></i>
        <h2>Check Your Email</h2>
        <p style="margin: 20px 0;">We sent a confirmation link to your email address.</p>
        <p style="color: var(--text-secondary);">Please click the link to activate your account.</p>
        <a href="/Account/Login" class="btn-premium" style="display: inline-block; margin-top: 25px;">Go to Login</a>
        <p style="margin-top: 20px;"><a href="/Account/ResendConfirmation" style="color: var(--accent);">Didn't get the email? Resend</a></p>
    </div>
</div>