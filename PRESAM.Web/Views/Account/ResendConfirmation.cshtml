@{
    ViewData["Title"] = "Resend Confirmation";
}
<div class="container" style="max-width: 450px;">
    <div class="premium-card">
        <h2 style="text-align: center; margin-bottom: 20px;">Resend Confirmation Email</h2>
        <form method="post">
            <input type="email" name="email" class="premium-input" placeholder="Enter your email" required />
            <button type="submit" class="btn-premium" style="width: 100%; margin-top: 20px;">Send Email</button>
        </form>
        <p style="text-align: center; margin-top: 20px;"><a href="/Account/Login" style="color: var(--accent);">Back to Login</a></p>
    </div>
</div>