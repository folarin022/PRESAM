@model PRESAM.Application.DTOs.OrderDto

@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="confirmation-container">
    <!-- Success Animation Header -->
    <div class="success-header">
        <div class="success-icon">
            <i class="fas fa-check-circle"></i>
            <div class="success-ring"></div>
        </div>
        <h1>Thank You for Your Order!</h1>
        <p>Your order has been placed successfully</p>
        <div class="order-badge">ORDER #@Model.OrderNumber</div>
    </div>

    <div class="confirmation-grid">
        <!-- Order Summary Card -->
        <div class="summary-card">
            <h3><i class="fas fa-receipt"></i> Order Summary</h3>
            
            <div class="order-info">
                <div class="info-row">
                    <span><i class="fas fa-calendar-alt"></i> Order Date</span>
                    <span>@Model.OrderDate.ToString("MMMM dd, yyyy")</span>
                </div>
                <div class="info-row">
                    <span><i class="fas fa-clock"></i> Order Time</span>
                    <span>@Model.OrderDate.ToString("hh:mm tt")</span>
                </div>
                <div class="info-row">
                    <span><i class="fas fa-tag"></i> Status</span>
                    <span class="status-badge">@Model.Status</span>
                </div>
                <div class="info-row">
                    <span><i class="fas fa-credit-card"></i> Payment Method</span>
                    <span>@Model.PaymentMethod</span>
                </div>
            </div>
        </div>

        <!-- Shipping Card -->
        <div class="shipping-card">
            <h3><i class="fas fa-truck"></i> Shipping Information</h3>
            <div class="shipping-address">
                <i class="fas fa-map-marker-alt"></i>
                <p>@Model.ShippingAddress</p>
            </div>
            <div class="delivery-estimate">
                <i class="fas fa-clock"></i>
                <span>Estimated delivery: 3-5 business days</span>
            </div>
        </div>
    </div>

    <!-- Items Card -->
    <div class="items-card">
        <h3><i class="fas fa-boxes"></i> Items in Your Order</h3>
        
        <div class="items-table">
            <div class="table-header">
                <span>Product</span>
                <span>Price</span>
                <span>Quantity</span>
                <span>Total</span>
            </div>
            
            @foreach (var item in Model.Items)
            {
                <div class="table-row">
                    <span class="product-name">
                        <i class="fas fa-cube"></i> @item.ProductName
                    </span>
                    <span>₦@item.UnitPrice.ToString("N0")</span>
                    <span>@item.Quantity</span>
                    <span class="product-total">₦@item.TotalPrice.ToString("N0")</span>
                </div>
            }
        </div>
        
        <div class="total-section">
            <div class="total-row">
                <span>Subtotal</span>
                <span>₦@(Model.TotalAmount.ToString("N0"))</span>
            </div>
            <div class="total-row">
                <span>Shipping</span>
                <span>₦2,000</span>
            </div>
            <div class="total-row">
                <span>Tax (7.5%)</span>
                <span>₦@((Model.TotalAmount * 0.075m).ToString("N0"))</span>
            </div>
            <div class="total-row grand-total">
                <span>Grand Total</span>
                <span>₦@((Model.TotalAmount + 2000 + (Model.TotalAmount * 0.075m)).ToString("N0"))</span>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <a href="/Product/Index" class="btn-primary">
            <i class="fas fa-shopping-bag"></i> Continue Shopping
        </a>
        <a href="/Order/MyOrders" class="btn-secondary">
            <i class="fas fa-list"></i> View My Orders
        </a>
        <button onclick="window.print()" class="btn-print">
            <i class="fas fa-print"></i> Print Receipt
        </button>
    </div>

    <!-- Share Section -->
    <div class="share-section">
        <p>Share your purchase</p>
        <div class="share-icons">
            <a href="#"><i class="fab fa-whatsapp"></i></a>
            <a href="#"><i class="fab fa-facebook"></i></a>
            <a href="#"><i class="fab fa-twitter"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
        </div>
    </div>
</div>

<style>
    .confirmation-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    /* Success Header */
    .success-header {
        text-align: center;
        margin-bottom: 40px;
        padding: 30px;
        background: linear-gradient(135deg, rgba(46, 204, 113, 0.1) 0%, rgba(46, 204, 113, 0.05) 100%);
        border-radius: 30px;
    }

    .success-icon {
        position: relative;
        display: inline-block;
        margin-bottom: 20px;
    }

    .success-icon i {
        font-size: 80px;
        color: #2ecc71;
        animation: bounce 0.5s ease;
    }

    .success-ring {
        position: absolute;
        top: -10px;
        left: -10px;
        right: -10px;
        bottom: -10px;
        border: 3px solid #2ecc71;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }

    @@keyframes bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(1.5); opacity: 0; }
    }

    .success-header h1 {
        font-size: 32px;
        margin-bottom: 10px;
        color: var(--text-primary);
    }

    .success-header p {
        color: var(--text-secondary);
        margin-bottom: 15px;
    }

    .order-badge {
        display: inline-block;
        background: var(--bg-card);
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 600;
        border: 1px solid var(--border);
        color: var(--accent);
    }

    /* Grid Layout */
    .confirmation-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    /* Cards */
    .summary-card, .shipping-card, .items-card {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 25px;
        border: 1px solid var(--border);
    }

    .summary-card h3, .shipping-card h3, .items-card h3 {
        font-size: 18px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--border);
    }

    .summary-card h3 i, .shipping-card h3 i, .items-card h3 i {
        color: var(--accent);
        margin-right: 8px;
    }

    /* Order Info */
    .order-info {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 14px;
    }

    .info-row span:first-child {
        color: var(--text-secondary);
    }

    .info-row span:first-child i {
        margin-right: 8px;
        width: 16px;
        color: var(--accent);
    }

    .status-badge {
        background: #2ecc71;
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
    }

    /* Shipping */
    .shipping-address {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        padding: 15px;
        background: var(--bg-primary);
        border-radius: 12px;
    }

    .shipping-address i {
        color: var(--accent);
        font-size: 18px;
    }

    .shipping-address p {
        line-height: 1.5;
        color: var(--text-primary);
    }

    .delivery-estimate {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px;
        background: rgba(46, 204, 113, 0.1);
        border-radius: 12px;
        color: #2ecc71;
        font-size: 14px;
    }

    /* Items Table */
    .items-table {
        width: 100%;
    }

    .table-header {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        padding: 12px 0;
        border-bottom: 2px solid var(--border);
        font-weight: 600;
        font-size: 13px;
        color: var(--text-secondary);
    }

    .table-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        padding: 14px 0;
        border-bottom: 1px solid var(--border);
        font-size: 14px;
    }

    .product-name {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .product-name i {
        color: var(--accent);
    }

    .product-total {
        font-weight: 600;
        color: var(--accent);
    }

    /* Total Section */
    .total-section {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 2px solid var(--border);
        text-align: right;
    }

    .total-row {
        display: flex;
        justify-content: flex-end;
        gap: 30px;
        padding: 5px 0;
        font-size: 14px;
    }

    .total-row span:first-child {
        width: 120px;
        text-align: left;
        color: var(--text-secondary);
    }

    .grand-total {
        font-size: 18px;
        font-weight: bold;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px solid var(--border);
    }

    .grand-total span:last-child {
        color: var(--accent);
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin: 30px 0;
        flex-wrap: wrap;
    }

    .btn-primary, .btn-secondary, .btn-print {
        padding: 12px 28px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        color: black;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(198, 164, 63, 0.3);
    }

    .btn-secondary {
        background: transparent;
        border: 1px solid var(--accent);
        color: var(--accent);
    }

    .btn-secondary:hover {
        background: var(--accent);
        color: black;
    }

    .btn-print {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        cursor: pointer;
    }

    .btn-print:hover {
        border-color: var(--accent);
        color: var(--accent);
    }

    /* Share Section */
    .share-section {
        text-align: center;
        padding-top: 30px;
        border-top: 1px solid var(--border);
    }

    .share-section p {
        color: var(--text-secondary);
        margin-bottom: 15px;
        font-size: 14px;
    }

    .share-icons {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .share-icons a {
        width: 40px;
        height: 40px;
        background: var(--bg-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.3s;
    }

    .share-icons a:hover {
        background: var(--accent);
        color: black;
        transform: translateY(-3px);
    }

    /* Responsive */
    @@media (max-width: 700px) {
        .confirmation-grid {
            grid-template-columns: 1fr;
        }
        .table-header, .table-row {
            grid-template-columns: 1.5fr 0.8fr 0.8fr 1fr;
            font-size: 12px;
        }
        .action-buttons {
            flex-direction: column;
            align-items: center;
        }
        .btn-primary, .btn-secondary, .btn-print {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<script>
    // Confetti effect on page load
    function createConfetti() {
        const colors = ['#2ecc71', '#c6a43f', '#e74c3c', '#3498db', '#9b59b6'];
        for (let i = 0; i < 100; i++) {
            const confetti = document.createElement('div');
            confetti.style.position = 'fixed';
            confetti.style.width = Math.random() * 10 + 5 + 'px';
            confetti.style.height = Math.random() * 10 + 5 + 'px';
            confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
            confetti.style.left = Math.random() * 100 + '%';
            confetti.style.top = '-20px';
            confetti.style.borderRadius = '50%';
            confetti.style.opacity = Math.random();
            confetti.style.pointerEvents = 'none';
            confetti.style.zIndex = '9999';
            confetti.style.animation = `fall ${Math.random() * 3 + 2}s linear forwards`;
            document.body.appendChild(confetti);
            
            setTimeout(() => confetti.remove(), 5000);
        }
    }

    // Add keyframes dynamically
    const style = document.createElement('style');
    style.textContent = `
        @@keyframes fall {
            to {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }
    `;
    document.head.appendChild(style);

    // Trigger confetti when page loads
    createConfetti();
</script>