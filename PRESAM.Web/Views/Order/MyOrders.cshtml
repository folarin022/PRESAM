@model IEnumerable<PRESAM.Application.DTOs.OrderDto>

@{
    ViewData["Title"] = "My Orders";
}

<div class="container">
    <h2 style="margin-bottom: 30px;">My Orders</h2>
    
    @if (Model != null && Model.Any())
    {
        <div style="display: grid; gap: 20px;">
            @foreach (var order in Model)
            {
                <div class="premium-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
                        <div>
                            <strong>Order #@order.OrderNumber</strong>
                            <br />
                            <small>@order.OrderDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div>
                            <span style="background: var(--accent); padding: 5px 15px; border-radius: 50px;">@order.Status</span>
                        </div>
                        <div>
                            <strong>₦@order.TotalAmount.ToString("N0")</strong>
                        </div>
                        <div>
                            <a href="/Order/OrderConfirmation/@order.Id" class="btn-premium" style="padding: 8px 20px;">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="premium-card" style="text-align: center;">
            <i class="fas fa-box-open" style="font-size: 50px; margin-bottom: 15px;"></i>
            <h3>No orders yet</h3>
            <p>Start shopping to see your orders here</p>
            <a href="/Product/Index" class="btn-premium">Start Shopping</a>
        </div>
    }
</div>