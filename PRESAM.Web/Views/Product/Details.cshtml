@model PRESAM.Application.DTOs.ProductDto

@{
    ViewData["Title"] = Model.Name;
    Layout = "_Layout";
}

<div class="product-detail-container">
    <div class="product-grid">
        <!-- Left Column - Product Image Gallery -->
        <div class="product-gallery">
            <div class="main-image">
                <img src="@Model.ImageUrl" alt="@Model.Name" id="mainProductImage" />
            </div>
            <div class="thumbnail-list">
                <div class="thumbnail active" onclick="changeImage('@Model.ImageUrl')">
                    <img src="@Model.ImageUrl" alt="Thumbnail" />
                </div>
                <div class="thumbnail" onclick="changeImage('@Model.ImageUrl')">
                    <img src="@Model.ImageUrl" alt="Thumbnail" />
                </div>
                <div class="thumbnail" onclick="changeImage('@Model.ImageUrl')">
                    <img src="@Model.ImageUrl" alt="Thumbnail" />
                </div>
            </div>
        </div>

        <!-- Right Column - Product Info -->
        <div class="product-info">
            <!-- Category Badge -->
            <div class="category-badge">
                <i class="fas fa-tag"></i> @Model.CategoryName
            </div>

            <!-- Product Title -->
            <h1 class="product-title">@Model.Name</h1>

            <!-- Rating Section -->
            <div class="rating">
                <div class="stars">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star-half-alt"></i>
                </div>
                <span class="rating-count">(124 customer reviews)</span>
            </div>

            <div class="price-section">
                <span class="current-price">₦@Model.Price.ToString("N0")</span>
                <span class="old-price">₦@((Model.Price * 1.2m).ToString("N0"))</span>
                <span class="discount-badge">-20%</span>
            </div>

            <!-- Stock Status -->
            <div class="stock-status @(Model.StockQuantity > 0 ? "in-stock" : "out-of-stock")">
                <i class="fas @(Model.StockQuantity > 0 ? "fa-check-circle" : "fa-times-circle")"></i>
                @if (Model.StockQuantity > 0)
                {
                    <span>In Stock • @Model.StockQuantity units available</span>
                }
                else
                {
                    <span>Out of Stock</span>
                }
            </div>

            <!-- Description -->
            <div class="description">
                <h3>Product Description</h3>
                <p>@Model.Description</p>
            </div>

            <!-- Features -->
            <div class="features">
                <h3>Key Features</h3>
                <ul>
                    <li><i class="fas fa-check"></i> High quality material</li>
                    <li><i class="fas fa-check"></i> 1 year warranty</li>
                    <li><i class="fas fa-check"></i> Free shipping on orders over ₦50,000</li>
                    <li><i class="fas fa-check"></i> 30-day money back guarantee</li>
                </ul>
            </div>

            <!-- Quantity and Actions -->
            <div class="actions">
                <div class="quantity-box">
                    <button class="qty-btn" onclick="decrementQty()">-</button>
                    <input type="number" id="quantity" value="1" min="1" max="@Model.StockQuantity" />
                    <button class="qty-btn" onclick="incrementQty()">+</button>
                </div>

                <div class="action-buttons">
                    <button class="btn-add-to-cart" onclick="addToCart()">
                        <i class="fas fa-shopping-cart"></i> Add to Cart
                    </button>
                    <button class="btn-buy-now" onclick="buyNow()">
                        <i class="fas fa-bolt"></i> Buy Now
                    </button>
                </div>
            </div>

            <!-- Delivery Info -->
            <div class="delivery-info">
                <div class="delivery-item">
                    <i class="fas fa-truck"></i>
                    <div>
                        <strong>Free Delivery</strong>
                        <span>Enter your postal code for delivery availability</span>
                    </div>
                </div>
                <div class="delivery-item">
                    <i class="fas fa-undo-alt"></i>
                    <div>
                        <strong>Easy Returns</strong>
                        <span>30-day return policy</span>
                    </div>
                </div>
                <div class="delivery-item">
                    <i class="fas fa-shield-alt"></i>
                    <div>
                        <strong>Secure Payment</strong>
                        <span>100% secure payment methods</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products Section -->
    <div class="related-products">
        <h2 class="section-title">You May Also Like</h2>
        <div class="related-grid">
            <div class="related-card">
                <img src="https://via.placeholder.com/200" alt="Related product">
                <h4>Related Product 1</h4>
                <p>₦5,000</p>
                <button class="btn-view">View</button>
            </div>
            <div class="related-card">
                <img src="https://via.placeholder.com/200" alt="Related product">
                <h4>Related Product 2</h4>
                <p>₦7,500</p>
                <button class="btn-view">View</button>
            </div>
            <div class="related-card">
                <img src="https://via.placeholder.com/200" alt="Related product">
                <h4>Related Product 3</h4>
                <p>₦10,000</p>
                <button class="btn-view">View</button>
            </div>
            <div class="related-card">
                <img src="https://via.placeholder.com/200" alt="Related product">
                <h4>Related Product 4</h4>
                <p>₦3,000</p>
                <button class="btn-view">View</button>
            </div>
        </div>
    </div>
</div>

<style>
    .product-detail-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px;
    }

    .product-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 50px;
        background: var(--bg-card);
        border-radius: 30px;
        padding: 40px;
        border: 1px solid var(--border);
    }

    /* Gallery Styles */
    .main-image {
        width: 100%;
        height: 400px;
        border-radius: 20px;
        overflow: hidden;
        background: var(--bg-primary);
    }

        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .thumbnail-list {
        display: flex;
        gap: 12px;
        margin-top: 20px;
    }

    .thumbnail {
        width: 80px;
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
    }

        .thumbnail.active {
            border-color: var(--accent);
        }

        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Product Info Styles */
    .category-badge {
        display: inline-block;
        background: rgba(198, 164, 63, 0.1);
        color: var(--accent);
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        margin-bottom: 15px;
    }

    .product-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 15px;
        color: var(--text-primary);
    }

    .rating {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }

    .stars {
        color: #f39c12;
        font-size: 14px;
    }

    .rating-count {
        font-size: 13px;
        color: var(--text-secondary);
    }

    .price-section {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 20px;
    }

    .current-price {
        font-size: 32px;
        font-weight: 800;
        color: var(--accent);
    }

    .old-price {
        font-size: 18px;
        color: var(--text-secondary);
        text-decoration: line-through;
    }

    .discount-badge {
        background: #e74c3c;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .stock-status {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 25px;
        font-size: 14px;
    }

        .stock-status.in-stock {
            color: #2ecc71;
        }

        .stock-status.out-of-stock {
            color: #e74c3c;
        }

    .description, .features {
        margin-bottom: 25px;
    }

        .description h3, .features h3 {
            font-size: 18px;
            margin-bottom: 10px;
        }

        .description p {
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .features ul {
            list-style: none;
            padding: 0;
        }

        .features li {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
            color: var(--text-secondary);
            font-size: 14px;
        }

            .features li i {
                color: var(--accent);
                font-size: 12px;
            }

    .quantity-box {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .qty-btn {
        width: 40px;
        height: 40px;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 12px;
        cursor: pointer;
        font-size: 18px;
        color: var(--text-primary);
    }

    .quantity-box input {
        width: 60px;
        height: 40px;
        text-align: center;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-size: 16px;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        margin-bottom: 30px;
    }

    .btn-add-to-cart {
        flex: 1;
        padding: 14px;
        background: transparent;
        border: 2px solid var(--accent);
        border-radius: 50px;
        color: var(--accent);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-add-to-cart:hover {
            background: var(--accent);
            color: black;
        }

    .btn-buy-now {
        flex: 1;
        padding: 14px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        border: none;
        border-radius: 50px;
        color: black;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-buy-now:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(198, 164, 63, 0.3);
        }

    .delivery-info {
        border-top: 1px solid var(--border);
        padding-top: 20px;
    }

    .delivery-item {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 15px;
    }

        .delivery-item i {
            width: 35px;
            height: 35px;
            background: var(--bg-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent);
        }

        .delivery-item div {
            display: flex;
            flex-direction: column;
        }

        .delivery-item strong {
            font-size: 13px;
        }

        .delivery-item span {
            font-size: 11px;
            color: var(--text-secondary);
        }

    /* Related Products */
    .related-products {
        margin-top: 60px;
    }

    .section-title {
        font-size: 24px;
        margin-bottom: 25px;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    .related-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 15px;
        text-align: center;
        transition: all 0.2s;
    }

        .related-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
        }

        .related-card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 10px;
        }

        .related-card h4 {
            font-size: 14px;
            margin-bottom: 5px;
        }

        .related-card p {
            color: var(--accent);
            font-weight: bold;
            margin-bottom: 10px;
        }

    .btn-view {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        padding: 6px 20px;
        border-radius: 20px;
        cursor: pointer;
        color: var(--text-secondary);
    }

    @@media (max-width: 900px) {
        .product-grid {
            grid-template-columns: 1fr;
            padding: 25px;
        }

        .action-buttons {
            flex-direction: column;
        }
    }
</style>

<script>
    let currentQuantity = 1;
    const maxStock = @Model.StockQuantity;

    function changeImage(src) {
        document.getElementById('mainProductImage').src = src;
        document.querySelectorAll('.thumbnail').forEach(thumb => {
            thumb.classList.remove('active');
        });
        event.currentTarget.classList.add('active');
    }

    function incrementQty() {
        if (currentQuantity < maxStock) {
            currentQuantity++;
            document.getElementById('quantity').value = currentQuantity;
        }
    }

    function decrementQty() {
        if (currentQuantity > 1) {
            currentQuantity--;
            document.getElementById('quantity').value = currentQuantity;
        }
    }

    document.getElementById('quantity').addEventListener('change', function() {
        let val = parseInt(this.value);
        if (isNaN(val)) val = 1;
        if (val < 1) val = 1;
        if (val > maxStock) val = maxStock;
        currentQuantity = val;
        this.value = val;
    });

    function addToCart() {
        const quantity = document.getElementById('quantity').value;
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ productId: '@Model.Id', quantity: parseInt(quantity) })
        }).then(response => {
            if (response.ok) {
                showToast('✓ Added to cart!');
                updateCartCount();
            }
        });
    }

    function buyNow() {
        const quantity = document.getElementById('quantity').value;
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Order/BuyNow';
        form.innerHTML = `
            <input type="hidden" name="productId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="${quantity}" />
        `;
        document.body.appendChild(form);
        form.submit();
    }

    function showToast(message) {
        const toast = document.createElement('div');
        toast.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
        toast.style.cssText = `
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #2ecc71;
            color: black;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: 600;
            z-index: 9999;
            animation: slideIn 0.3s ease;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    const style = document.createElement('style');
    style.textContent = `
        @@keyframes slideIn {
            from { transform: translateX(100px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    `;
    document.head.appendChild(style);
</script>