@model IEnumerable<PRESAM.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = $"Search: {ViewBag.SearchTerm}";
}
<div class="container">
    <h2 style="margin-bottom: 20px;">Search Results for "@ViewBag.SearchTerm"</h2>
    <p style="margin-bottom: 30px;">Found @Model.Count() products</p>
    @if (Model != null && Model.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
            @foreach (var product in Model)
            {
                <div class="premium-card">
                    <img src="@product.ImageUrl" style="width: 100%; height: 200px; object-fit: cover;">
                    <h3>@product.Name</h3>
                    <p>₦@product.Price.ToString("N0")</p>
                    <a href="/Product/Details/@product.Id" class="btn-premium">View</a>
                </div>
            }
        </div>
    }
    else
    {
        <p>No products found matching your search.</p>
    }
</div>