@model IEnumerable<PRESAM.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = "Shop";
}
<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px;">
        <h2>All Products</h2>
        <div style="display: flex; gap: 15px;">
            <form action="/Product/Search" method="get">
                <input type="text" name="searchTerm" class="premium-input" placeholder="Search products..." style="width: 250px;" />
                <button type="submit" class="btn-premium" style="padding: 12px 20px;"><i class="fas fa-search"></i></button>
            </form>
            @if (User.IsInRole("Admin"))
            {
                <a href="/Product/Create" class="btn-premium">+ Add Product</a>
            }
        </div>
    </div>
    @if (Model != null && Model.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
            @foreach (var product in Model)
            {
                <div class="premium-card">
                    <img src="@product.ImageUrl" style="width: 100%; height: 220px; object-fit: cover; border-radius: 15px; margin-bottom: 15px;">
                    <h3>@product.Name</h3>
                    <p style="color: var(--accent); font-weight: 600;">₦@product.Price.ToString("N0")</p>
                    <div style="display: flex; gap: 10px; margin-top: 15px;">
                        <a href="/Product/Details/@product.Id" class="btn-premium" style="padding: 8px 15px; font-size: 13px;">View</a>
                        @if (User.Identity.IsAuthenticated && product.StockQuantity > 0)
                        {
                            <button onclick="addToCart('@product.Id')" class="btn-premium" style="padding: 8px 15px; font-size: 13px;">Add to Cart</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p style="text-align: center;">No products found.</p>
    }
</div>
<script>
    function addToCart(id) { $.post('/Cart/AddToCart', { productId: id, quantity: 1 }).done(function() { alert('Added to cart!'); updateCartCount(); }); }
</script>