@model IEnumerable<PRESAM.Application.DTOs.ProductDto>

@{
    ViewData["Title"] = "Shop";
}

@if (Model == null || !Model.Any())
{
    <div class="empty-shop">
        <i class="fas fa-box-open"></i>
        <h3>No Products Found</h3>
        <p>Check back soon for new arrivals!</p>

        @if (User.IsInRole("Admin"))
        {
            <a href="Product/Create" class="empty-add-btn">
                <i class="fas fa-plus"></i> Add Your First Product
            </a>
        }
    </div>
}
else
{
    <div class="shop-container">
        <!-- Page Header -->
        <div class="shop-header">
            <div>
                <h1 class="shop-title">Our Collection</h1>
                <p class="shop-subtitle">Discover quality products at amazing prices</p>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="admin-actions">
                <a href="/Admin/CreateProduct" class="add-product-btn">
                    <i class="fas fa-plus-circle"></i> Add New Product
                </a>
                <a href="/Admin/CreateCategory" class="add-category-btn">
                    <i class="fas fa-folder-plus"></i> Add Category
                </a>
            </div>
         }
        <div class="filters-bar">
            <div class="sort-group">
                <select id="sortSelect" onchange="sortProducts()" class="sort-select">
                    <option value="default">Sort by: Featured</option>
                    <option value="price-low">Price: Low to High</option>
                    <option value="price-high">Price: High to Low</option>
                    <option value="name-asc">Name: A to Z</option>
                </select>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="products-grid" id="productsGrid">
            @foreach (var product in Model)
            {
                <div class="product-card"
                     data-category="@(product.CategoryName?.ToLower() ?? "")"
                     data-price="@product.Price"
                     data-name="@(product.Name ?? "")">
                    <div class="product-badge" style="background: @(product.StockQuantity > 0 ? "#2ecc71" : "#e74c3c");">
                        @(product.StockQuantity > 0 ? "In Stock" : "Sold Out")
                    </div>
                    <div class="product-image">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" alt="@(product.Name ?? "Product")">
                        <div class="product-actions-overlay">
                            <button onclick="quickView('@product.Id')" class="quick-view-btn">
                                <i class="fas fa-eye"></i>
                            </button>
                            @if (User.Identity.IsAuthenticated && product.StockQuantity > 0)
                            {
                                <button onclick="addToCart('@product.Id')" class="quick-cart-btn">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="product-info">
                        <div class="product-category">@(product.CategoryName ?? "Uncategorized")</div>
                        <h3 class="product-name">@(product.Name ?? "Product Name")</h3>
                        <div class="product-price">
                            <span class="current-price">₦@(product.Price.ToString("N0"))</span>
                            <span class="old-price">₦@((product.Price * 1.2m).ToString("N0"))</span>
                        </div>
                        <div class="product-footer">
                            <a href="/Product/Details/@product.Id" class="view-details">View Details <i class="fas fa-arrow-right"></i></a>
                            @if (User.Identity.IsAuthenticated && product.StockQuantity > 0)
                            {
                                <button onclick="addToCart('@product.Id')" class="add-to-cart">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            }
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="admin-overlay">
                            <a href="/Admin/EditProduct/@product.Id" class="edit-btn">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button onclick="deleteProduct('@product.Id')" class="delete-btn">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .shop-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 30px;
    }

    /* Shop Header */
    .shop-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .shop-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 8px;
        background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .shop-subtitle {
        color: var(--text-secondary);
        font-size: 14px;
    }

    .product-count {
        background: var(--accent);
        color: black;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
    }

    /* Admin Actions */
    .admin-actions {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        justify-content: flex-end;
    }

    .add-product-btn, .add-category-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.2s;
    }

    .add-product-btn {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        color: black;
    }

    .add-category-btn {
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text-primary);
    }

        .add-product-btn:hover, .add-category-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(198, 164, 63, 0.3);
        }

    /* Filters Bar */
    .filters-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 40px;
        padding: 15px 20px;
        background: var(--bg-card);
        border-radius: 60px;
        border: 1px solid var(--border);
    }

    .filter-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-btn {
        background: transparent;
        border: none;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 14px;
        cursor: pointer;
        color: var(--text-secondary);
        transition: all 0.2s;
    }

        .filter-btn:hover {
            color: var(--accent);
        }

        .filter-btn.active {
            background: var(--accent);
            color: black;
            font-weight: 600;
        }

    .sort-select {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        padding: 8px 15px;
        border-radius: 40px;
        color: var(--text-primary);
        cursor: pointer;
        outline: none;
    }

    /* Products Grid */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 25px;
    }

    .product-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
    }

        .product-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
            box-shadow: 0 20px 30px -10px rgba(0,0,0,0.2);
        }

    /* Admin Overlay on Product Card */
    .admin-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
        padding: 10px;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .product-card:hover .admin-overlay {
        opacity: 1;
    }

    .edit-btn, .delete-btn {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }

    .edit-btn {
        background: var(--accent);
        color: black;
    }

    .delete-btn {
        background: #e74c3c;
        color: white;
    }

        .edit-btn:hover, .delete-btn:hover {
            transform: scale(1.05);
        }

    .product-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        color: black;
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        z-index: 5;
    }

    .product-image {
        position: relative;
        height: 240px;
        overflow: hidden;
        background: var(--bg-primary);
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

    .product-card:hover .product-image img {
        transform: scale(1.08);
    }

    .product-actions-overlay {
        position: absolute;
        bottom: -50px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: center;
        gap: 12px;
        padding: 15px;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        transition: bottom 0.3s ease;
    }

    .product-card:hover .product-actions-overlay {
        bottom: 0;
    }

    .quick-view-btn, .quick-cart-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 16px;
    }

    .quick-view-btn {
        color: #3498db;
    }

    .quick-cart-btn {
        color: #2ecc71;
    }

        .quick-view-btn:hover, .quick-cart-btn:hover {
            transform: scale(1.1);
        }

    .product-info {
        padding: 18px;
    }

    .product-category {
        font-size: 11px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .product-name {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .product-price {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }

    .current-price {
        font-size: 20px;
        font-weight: 700;
        color: var(--accent);
    }

    .old-price {
        font-size: 13px;
        color: var(--text-secondary);
        text-decoration: line-through;
    }

    .product-rating {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 15px;
    }

    .stars {
        color: #f39c12;
        font-size: 12px;
    }

    .product-rating span {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 12px;
        border-top: 1px solid var(--border);
    }

    .view-details {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s;
    }

        .view-details:hover {
            color: var(--accent);
        }

        .view-details i {
            font-size: 11px;
            transition: transform 0.2s;
        }

        .view-details:hover i {
            transform: translateX(3px);
        }

    .add-to-cart {
        background: var(--accent);
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 10px;
        color: black;
        cursor: pointer;
        transition: all 0.2s;
    }

        .add-to-cart:hover {
            transform: scale(1.05);
        }

    /* Empty State */
    .empty-shop {
        text-align: center;
        padding: 80px;
        background: var(--bg-card);
        border-radius: 30px;
        border: 1px solid var(--border);
        max-width: 600px;
        margin: 50px auto;
    }

        .empty-shop i {
            font-size: 70px;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .empty-shop h3 {
            font-size: 24px;
            margin-bottom: 10px;
        }

        .empty-shop p {
            color: var(--text-secondary);
        }

    .empty-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent);
        color: black;
        padding: 12px 28px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 20px;
        transition: all 0.2s;
    }

        .empty-add-btn:hover {
            transform: translateY(-2px);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .shop-container {
            padding: 0 20px;
        }

        .filters-bar {
            flex-direction: column;
            align-items: stretch;
            border-radius: 20px;
        }

        .filter-group {
            justify-content: center;
        }

        .sort-select {
            width: 100%;
        }

        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
        }

        .admin-actions {
            justify-content: center;
        }
    }
</style>

<script>
    function filterProducts(category) {
        const buttons = document.querySelectorAll('.filter-btn');
        buttons.forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');

        const products = document.querySelectorAll('.product-card');
        
        products.forEach(product => {
            if (category === 'all') {
                product.style.display = 'block';
            } else {
                const productCategory = product.getAttribute('data-category');
                if (productCategory === category) {
                    product.style.display = 'block';
                } else {
                    product.style.display = 'none';
                }
            }
        });
    }

    function sortProducts() {
        const sortValue = document.getElementById('sortSelect').value;
        const grid = document.getElementById('productsGrid');
        const products = Array.from(document.querySelectorAll('.product-card'));
        
        if (sortValue === 'price-low') {
            products.sort((a, b) => parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price')));
        } else if (sortValue === 'price-high') {
            products.sort((a, b) => parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price')));
        } else if (sortValue === 'name-asc') {
            products.sort((a, b) => a.getAttribute('data-name').localeCompare(b.getAttribute('data-name')));
        } else {
            return;
        }
        
        products.forEach(product => grid.appendChild(product));
    }

    function addToCart(productId) {
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: productId, quantity: 1 })
        }).then(response => {
            if (response.ok) {
                showToast('✓ Added to cart!');
                if (typeof updateCartCount === 'function') {
                    updateCartCount();
                }
            }
        }).catch(error => {
            console.error('Error:', error);
        });
    }

    function quickView(productId) {
        window.location.href = '/Product/Details/' + productId;
    }

    function deleteProduct(productId) {
        if (confirm('Are you sure you want to delete this product?')) {
            fetch('/Admin/DeleteProduct', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: productId })
            }).then(response => response.json()).then(data => {
                if (data.success) {
                    showToast('Product deleted!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    alert(data.message);
                }
            });
        }
    }

    function showToast(message) {
        const toast = document.createElement('div');
        toast.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
        toast.style.cssText = `
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #2ecc71;
            color: black;
            padding: 12px 24px;
            border-radius: 50px;
            font-weight: 600;
            z-index: 9999;
            animation: slideIn 0.3s ease;
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>