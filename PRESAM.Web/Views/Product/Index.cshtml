@model IEnumerable<PRESAM.Application.DTOs.ProductDto>

@{
    ViewData["Title"] = "Shop";
    var categories = ViewBag.Categories as IEnumerable<PRESAM.Application.DTOs.CategoryDto>;
}

@if (Model == null || !Model.Any())
{
    <div class="empty-shop">
        <i class="fas fa-box-open"></i>
        <h3>No Products Found</h3>
        <p>Check back soon for new arrivals!</p>
        @if (User.IsInRole("Admin"))
        {
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="/Admin/CreateCategory" class="empty-add-btn" style="background: var(--bg-card); border: 1px solid var(--accent); color: var(--accent);">
                    <i class="fas fa-folder-plus"></i> Add Category First
                </a>
                <a href="/Admin/CreateProduct" class="empty-add-btn">
                    <i class="fas fa-plus"></i> Add Product
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="shop-container">
        <!-- Hero Banner -->
        <div class="hero-banner">
            <div class="hero-content">
                <span class="hero-badge">New Collection</span>
                <h1 class="hero-title">Discover <span class="accent">Premium</span> Quality</h1>
                <p class="hero-desc">Shop the latest trends with amazing discounts. Free shipping on orders over ₦50,000.</p>
                <a href="#products" class="hero-btn">Shop Now →</a>
            </div>
            <div class="hero-image">
                <img src="https://picsum.photos/400/300?random=1" alt="Hero">
            </div>
        </div>

        <!-- Admin Actions -->
        @if (User.IsInRole("Admin"))
        {
            <div class="admin-actions">
                <a href="/Admin/CreateProduct" class="add-product-btn">
                    <i class="fas fa-plus-circle"></i> Add New Product
                </a>
                <a href="/Admin/CreateCategory" class="add-category-btn">
                    <i class="fas fa-folder-plus"></i> Add Category
                </a>
            </div>
        }

        <!-- Category Chips -->
        @if (categories != null && categories.Any())
        {
            <div class="category-chips">
                <span class="chip-label">Shop by category:</span>
                @foreach (var cat in categories.Take(6))
                {
                    <a href="/Product/ByCategory/@cat.Id" class="chip">
                        <i class="fas fa-tag"></i> @cat.Name
                    </a>
                }
                <a href="/Product/Index" class="chip chip-all">All products</a>
            </div>
        }

        <!-- Filters & Sort Bar -->
        <div class="filters-bar" id="products">
            <div class="filter-group">
                <button class="filter-btn active" onclick="filterProducts('all', event)">All</button>
                <button class="filter-btn" onclick="filterProducts('electronics', event)">Electronics</button>
                <button class="filter-btn" onclick="filterProducts('fashion', event)">Fashion</button>
                <button class="filter-btn" onclick="filterProducts('books', event)">Books</button>
            </div>
            <div class="sort-group">
                <select id="sortSelect" onchange="sortProducts()" class="sort-select">
                    <option value="default">Sort by: Featured</option>
                    <option value="price-low">Price: Low → High</option>
                    <option value="price-high">Price: High → Low</option>
                    <option value="name-asc">Name: A → Z</option>
                </select>
            </div>
        </div>

        <!-- Products Grid - SMALL CARDS -->
        <div class="products-grid" id="productsGrid">
            @foreach (var product in Model)
            {
                <div class="product-card"
                     data-category="@(product.CategoryName?.ToLower() ?? "")"
                     data-price="@product.Price"
                     data-name="@(product.Name ?? "")">
                    <div class="product-badge" style="background: @(product.StockQuantity > 0 ? "#2ecc71" : "#e74c3c");">
                        @(product.StockQuantity > 0 ? "In Stock" : "Sold Out")
                    </div>
                    <div class="product-image">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.jpg" : product.ImageUrl)" alt="@product.Name">
                        <div class="product-actions-overlay">
                            <button onclick="quickView('@product.Id')" class="quick-view-btn">
                                <i class="fas fa-eye"></i>
                            </button>
                            @if (User.Identity.IsAuthenticated && product.StockQuantity > 0)
                            {
                                <button onclick="addToCart('@product.Id')" class="quick-cart-btn">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            }
                        </div>
                    </div>
                    <div class="product-info">
                        <div class="product-category">@(product.CategoryName ?? "Uncategorized")</div>
                        <h3 class="product-name">@product.Name</h3>
                        <div class="product-price">
                            <span class="current-price">₦@product.Price.ToString("N0")</span>
                            <span class="old-price">₦@((product.Price * 1.2m).ToString("N0"))</span>
                        </div>
                        <div class="product-footer">
                            <a href="/Product/Details/@product.Id" class="view-details">View Details <i class="fas fa-arrow-right"></i></a>
                            @if (User.Identity.IsAuthenticated && product.StockQuantity > 0)
                            {
                                <button onclick="addToCart('@product.Id')" class="add-to-cart">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            }
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="admin-overlay">
                            <a href="/Admin/EditProduct/@product.Id" class="edit-btn">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <button onclick="deleteProduct('@product.Id')" class="delete-btn">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .shop-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 30px;
    }

    /* Hero Banner - Compact */
    .hero-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 30px;
        background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
        border-radius: 24px;
        padding: 30px 35px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }
    .hero-content { flex: 1; }
    .hero-badge {
        display: inline-block;
        background: var(--accent);
        color: black;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        margin-bottom: 12px;
    }
    .hero-title {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 12px;
    }
    .hero-title .accent { color: var(--accent); }
    .hero-desc {
        color: var(--text-secondary);
        margin-bottom: 20px;
        max-width: 400px;
        font-size: 14px;
    }
    .hero-btn {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        color: black;
        padding: 10px 24px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: 0.2s;
    }
    .hero-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(198,164,63,0.3); }
    .hero-image { flex: 1; text-align: center; }
    .hero-image img { max-width: 100%; max-height: 200px; object-fit: contain; border-radius: 16px; }

    /* Category Chips - Compact */
    .category-chips {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin-bottom: 25px;
    }
    .chip-label { font-weight: 500; color: var(--text-secondary); font-size: 12px; }
    .chip {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 5px 14px;
        text-decoration: none;
        color: var(--text-primary);
        font-size: 12px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .chip:hover, .chip.chip-all { background: var(--accent); color: black; border-color: var(--accent); }
    .chip i { font-size: 11px; }

    /* Admin Actions - Compact */
    .admin-actions {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
        justify-content: flex-end;
    }
    .add-product-btn, .add-category-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 20px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        font-size: 12px;
        transition: all 0.2s;
    }
    .add-product-btn { background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%); color: black; }
    .add-category-btn { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-primary); }
    .add-product-btn:hover, .add-category-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(198,164,63,0.3); }

    /* Filters Bar - Compact */
    .filters-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 30px;
        padding: 10px 18px;
        background: var(--bg-card);
        border-radius: 50px;
        border: 1px solid var(--border);
    }
    .filter-group { display: flex; gap: 6px; flex-wrap: wrap; }
    .filter-btn {
        background: transparent;
        border: none;
        padding: 5px 16px;
        border-radius: 30px;
        font-size: 13px;
        cursor: pointer;
        color: var(--text-secondary);
        transition: 0.2s;
    }
    .filter-btn:hover { color: var(--accent); }
    .filter-btn.active {
        background: #3498db !important;
        color: white !important;
    }
    .sort-select {
        background: var(--bg-primary);
        border: 1px solid var(--border);
        padding: 5px 12px;
        border-radius: 30px;
        color: var(--text-primary);
        cursor: pointer;
        font-size: 12px;
    }

    /* ========== SMALL PRODUCT CARDS ========== */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
    }

    .product-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: all 0.25s ease;
        position: relative;
    }
    .product-card:hover {
        transform: translateY(-3px);
        border-color: var(--accent);
        box-shadow: 0 8px 16px -6px rgba(0,0,0,0.15);
    }

    /* Badge - Tiny */
    .product-badge {
        position: absolute;
        top: 6px;
        left: 6px;
        color: black;
        font-size: 8px;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 14px;
        z-index: 2;
    }

    /* Product Image - Small */
    .product-image {
        position: relative;
        height: 140px;
        overflow: hidden;
        background: var(--bg-primary);
    }
    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.25s;
    }
    .product-card:hover .product-image img { transform: scale(1.04); }

    /* Action Buttons Overlay - Small */
    .product-actions-overlay {
        position: absolute;
        bottom: -38px;
        left: 0;
        right: 0;
        display: flex;
        justify-content: center;
        gap: 8px;
        padding: 8px;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        transition: bottom 0.25s;
    }
    .product-card:hover .product-actions-overlay { bottom: 0; }
    .quick-view-btn, .quick-cart-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: white;
        border: none;
        cursor: pointer;
        transition: 0.2s;
        font-size: 11px;
    }
    .quick-view-btn { color: #3498db; }
    .quick-cart-btn { color: #2ecc71; }
    .quick-view-btn:hover, .quick-cart-btn:hover { transform: scale(1.08); }

    /* Product Info - Compact */
    .product-info { padding: 10px; }
    .product-category {
        font-size: 9px;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 3px;
    }
    .product-name {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 5px;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .product-price {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 8px;
    }
    .current-price { font-size: 14px; font-weight: 700; color: var(--accent); }
    .old-price { font-size: 10px; color: var(--text-secondary); text-decoration: line-through; }

    /* Product Footer - Compact */
    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 6px;
        border-top: 1px solid var(--border);
    }
    .view-details {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 10px;
        font-weight: 500;
        transition: 0.2s;
    }
    .view-details:hover { color: var(--accent); }
    .view-details i { font-size: 8px; transition: transform 0.2s; }
    .view-details:hover i { transform: translateX(3px); }
    .add-to-cart {
        background: var(--accent);
        border: none;
        width: 24px;
        height: 24px;
        border-radius: 6px;
        color: black;
        cursor: pointer;
        transition: 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
    }
    .add-to-cart:hover { transform: scale(1.05); }

    /* Admin Overlay - Tiny */
    .admin-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.85), transparent);
        padding: 6px;
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        opacity: 0;
        transition: opacity 0.25s;
    }
    .product-card:hover .admin-overlay { opacity: 1; }
    .edit-btn, .delete-btn {
        padding: 2px 9px;
        border-radius: 14px;
        font-size: 9px;
        font-weight: 500;
        border: none;
        cursor: pointer;
    }
    .edit-btn { background: var(--accent); color: black; }
    .delete-btn { background: #e74c3c; color: white; }
    .edit-btn:hover, .delete-btn:hover { transform: scale(1.04); }

    /* Empty State */
    .empty-shop {
        text-align: center;
        padding: 60px;
        background: var(--bg-card);
        border-radius: 24px;
        border: 1px solid var(--border);
        max-width: 500px;
        margin: 50px auto;
    }
    .empty-shop i { font-size: 60px; color: var(--text-secondary); margin-bottom: 15px; }
    .empty-shop h3 { font-size: 22px; margin-bottom: 8px; }
    .empty-shop p { color: var(--text-secondary); font-size: 13px; }
    .empty-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent);
        color: black;
        padding: 10px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        font-size: 12px;
        margin-top: 15px;
    }
    .empty-add-btn:hover { transform: translateY(-2px); }

    @@media (max-width: 768px) {
        .shop-container { padding: 0 20px; }
        .hero-title { font-size: 26px; }
        .hero-banner { padding: 20px; gap: 20px; }
        .hero-image img { max-height: 150px; }
        .filters-bar { flex-direction: column; align-items: stretch; border-radius: 24px; }
        .filter-group { justify-content: center; }
        .sort-select { width: 100%; }
        .products-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
        .product-image { height: 120px; }
        .admin-actions { justify-content: center; }
        .product-name { font-size: 11px; }
        .current-price { font-size: 13px; }
    }

    @@media (max-width: 480px) {
        .products-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
        .product-image { height: 100px; }
        .product-info { padding: 8px; }
        .product-name { font-size: 10px; }
        .current-price { font-size: 12px; }
        .view-details { font-size: 9px; }
        .add-to-cart { width: 22px; height: 22px; font-size: 9px; }
    }
</style>

<script>
    function filterProducts(category, event) {
        const buttons = document.querySelectorAll('.filter-btn');
        buttons.forEach(btn => btn.classList.remove('active'));
        if (event && event.target) event.target.classList.add('active');

        const products = document.querySelectorAll('.product-card');
        products.forEach(product => {
            const productCategory = product.getAttribute('data-category');
            if (category === 'all' || productCategory === category)
                product.style.display = 'block';
            else
                product.style.display = 'none';
        });
    }

    function sortProducts() {
        const sortValue = document.getElementById('sortSelect').value;
        const grid = document.getElementById('productsGrid');
        const products = Array.from(document.querySelectorAll('.product-card'));

        if (sortValue === 'price-low') {
            products.sort((a, b) => parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price')));
        } else if (sortValue === 'price-high') {
            products.sort((a, b) => parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price')));
        } else if (sortValue === 'name-asc') {
            products.sort((a, b) => a.getAttribute('data-name').localeCompare(b.getAttribute('data-name')));
        } else {
            return;
        }
        products.forEach(p => grid.appendChild(p));
    }

    function addToCart(productId) {
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: productId, quantity: 1 })
        }).then(response => response.ok ? response : Promise.reject())
          .then(() => {
              showToast('✓ Added to cart!');
              if (typeof updateCartCount === 'function') updateCartCount();
          }).catch(error => console.error('Error:', error));
    }

    function quickView(productId) { 
        window.location.href = '/Product/Details/' + productId; 
    }

    function deleteProduct(productId) {
        if (confirm('Delete this product? This action cannot be undone.')) {
            fetch('/Admin/DeleteProduct', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: productId })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('✓ Product deleted!');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('✗ ' + (data.message || 'Delete failed'));
                }
            })
            .catch(error => {
                console.error('Delete error:', error);
                showToast('Failed to delete product');
            });
        }
    }

    function showToast(message) {
        const toast = document.createElement('div');
        const isSuccess = message.includes('✓');
        toast.innerHTML = isSuccess ? `<i class="fas fa-check-circle"></i> ${message}` : `<i class="fas fa-exclamation-circle"></i> ${message}`;
        toast.style.cssText = `
            position: fixed; bottom: 30px; right: 30px;
            background: ${isSuccess ? '#2ecc71' : '#e74c3c'}; 
            color: black; padding: 10px 20px;
            border-radius: 40px; font-weight: 600; z-index: 9999;
            font-size: 13px;
            animation: slideIn 0.3s ease;
        `;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>