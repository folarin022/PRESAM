@model IEnumerable<PRESAM.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = ViewBag.CategoryName;
}
<div class="container">
    <h2 style="margin-bottom: 30px;">@ViewBag.CategoryName</h2>
    @if (Model != null && Model.Any())
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
            @foreach (var product in Model)
            {
                <div class="premium-card">
                    <img src="@product.ImageUrl" style="width: 100%; height: 220px; object-fit: cover; border-radius: 15px;">
                    <h3>@product.Name</h3>
                    <p>₦@product.Price.ToString("N0")</p>
                    <a href="/Product/Details/@product.Id" class="btn-premium" style="display: inline-block; margin-top: 10px;">View</a>
                </div>
            }
        </div>
    }
</div>