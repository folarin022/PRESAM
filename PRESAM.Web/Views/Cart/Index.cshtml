@model PRESAM.Application.DTOs.CartDto
@{
    ViewData["Title"] = "My Cart";
}

<style>
    .cart-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    .cart-header {
        text-align: center;
        margin-bottom: 50px;
        position: relative;
    }

        .cart-header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, var(--text-primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 10px;
        }

        .cart-header p {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .cart-header::after {
            content: '';
            display: block;
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, var(--accent), transparent);
            margin: 20px auto 0;
            border-radius: 3px;
        }

    /* Premium Card Styles */
    .premium-card {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 25px;
        border: 1px solid var(--border);
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

        .premium-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(198, 164, 63, 0.1);
            border-color: rgba(198, 164, 63, 0.3);
        }

    /* Cart Item Styles */
    .cart-item {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        padding: 20px;
        background: var(--bg-card);
        border-radius: 16px;
        border: 1px solid var(--border);
        transition: all 0.3s ease;
        position: relative;
        align-items: center;
    }

        .cart-item:hover {
            transform: translateX(5px);
            border-color: rgba(198, 164, 63, 0.4);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

    .cart-item-image {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--bg-secondary), var(--bg-primary));
        padding: 10px;
    }

    .cart-item-details {
        flex: 1;
    }

    .cart-item-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .cart-item-category {
        font-size: 0.85rem;
        color: var(--accent);
        margin-bottom: 10px;
        display: inline-block;
        padding: 3px 10px;
        background: rgba(198, 164, 63, 0.1);
        border-radius: 20px;
    }

    .cart-item-price {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--accent);
    }

    .cart-item-original {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-decoration: line-through;
        margin-left: 10px;
    }

    .quantity-control {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--bg-primary);
        padding: 5px;
        border-radius: 30px;
        border: 1px solid var(--border);
    }

    .quantity-btn {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: none;
        background: var(--bg-secondary);
        color: var(--text-primary);
        cursor: pointer;
        transition: all 0.2s;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .quantity-btn:hover {
            background: var(--accent);
            color: #000;
            transform: scale(1.05);
        }

    .quantity-input {
        width: 50px;
        text-align: center;
        background: transparent;
        border: none;
        color: var(--text-primary);
        font-weight: 600;
        font-size: 1rem;
        padding: 5px;
    }

        .quantity-input:focus {
            outline: none;
        }

    .item-total {
        min-width: 120px;
        text-align: right;
    }

    .item-total-label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 5px;
    }

    .item-total-amount {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--accent);
    }

    .remove-btn {
        background: rgba(231, 76, 60, 0.1);
        border: 1px solid rgba(231, 76, 60, 0.3);
        padding: 10px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        color: #e74c3c;
    }

        .remove-btn:hover {
            background: #e74c3c;
            color: white;
            transform: scale(1.05);
        }

    /* Order Summary */
    .summary-card {
        position: sticky;
        top: 100px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px dashed var(--border);
    }

        .summary-row.total {
            border-bottom: none;
            margin-top: 10px;
            padding-top: 20px;
            font-size: 1.2rem;
        }

    .badge {
        background: var(--accent);
        color: #000;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-left: 10px;
    }

    .checkout-btn {
        display: block;
        width: 100%;
        text-align: center;
        background: linear-gradient(135deg, var(--accent), #d4b04c);
        color: #000;
        padding: 14px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 25px;
        transition: all 0.3s;
        border: none;
        cursor: pointer;
        font-size: 1rem;
    }

        .checkout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(198, 164, 63, 0.3);
        }

    .clear-cart-btn {
        background: transparent;
        border: 1px solid rgba(231, 76, 60, 0.5);
        color: #e74c3c;
        padding: 10px 20px;
        border-radius: 40px;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 20px;
    }

        .clear-cart-btn:hover {
            background: #e74c3c;
            color: white;
            border-color: #e74c3c;
        }

    /* Empty Cart */
    .empty-cart {
        text-align: center;
        padding: 80px 20px;
    }

    .empty-cart-icon {
        font-size: 80px;
        color: var(--accent);
        margin-bottom: 20px;
        opacity: 0.5;
    }

    .empty-cart h3 {
        font-size: 1.8rem;
        margin-bottom: 15px;
    }

    .shop-now-btn {
        display: inline-block;
        background: var(--accent);
        color: #000;
        padding: 12px 30px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 20px;
        transition: all 0.3s;
    }

        .shop-now-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(198, 164, 63, 0.3);
        }

    /* Responsive */
    @@media (max-width: 968px) {
        .cart-item {
            flex-wrap: wrap;
        }
        
        .item-total {
            text-align: left;
            width: 100%;
            margin-top: 10px;
        }
        
        .cart-header h1 {
            font-size: 1.8rem;
        }
    }
</style>

<div class="cart-container">
    <div class="cart-header">
        <h1><i class="fas fa-shopping-bag"></i> My Shopping Cart</h1>
        <p>Review and manage your precious items</p>
    </div>

    @if (Model != null && Model.Items.Any())
    {
        <div style="display: grid; grid-template-columns: 1fr 380px; gap: 30px;">
            <!-- Cart Items -->
            <div>
                @foreach (var item in Model.Items)
                {
                    <div class="cart-item">
                        <img src="@item.ProductImage" class="cart-item-image" alt="@item.ProductName" onerror="this.src='https://placehold.co/400x400/1a1a1a/c6a43f?text=PRESAM'">
                        
                        <div class="cart-item-details">
                            <div class="cart-item-title">@item.ProductName</div>
                            <div class="cart-item-category">
                                <i class="fas fa-tag"></i> Premium Collection
                            </div>
                            <div>
                                <span class="cart-item-price">₦@item.UnitPrice.ToString("N0")</span>
                            </div>
                        </div>
                        
                        <div class="quantity-control">
                            <button class="quantity-btn" onclick="updateQuantity(@item.Id, @(item.Quantity - 1))">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" class="quantity-input" id="qty_@item.Id" value="@item.Quantity" min="1" readonly>
                            <button class="quantity-btn" onclick="updateQuantity(@item.Id, @(item.Quantity + 1))">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        
                        <div class="item-total">
                            <div class="item-total-label">Total</div>
                            <div class="item-total-amount">₦@item.TotalPrice.ToString("N0")</div>
                        </div>
                        
                        <button class="remove-btn" onclick="removeItem(@item.Id)" title="Remove item">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                }
                
                <div style="display: flex; justify-content: flex-end; margin-top: 20px;">
                    <button class="clear-cart-btn" onclick="clearCart()">
                        <i class="fas fa-trash"></i> Clear Cart
                    </button>
                </div>
            </div>
            
            <!-- Order Summary -->
            <div>
                <div class="premium-card summary-card">
                    <h3 style="margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-receipt" style="color: var(--accent);"></i>
                        Order Summary
                    </h3>
                    
                    <div class="summary-row">
                        <span>Items (<span id="totalItems">@Model.TotalItems</span>)</span>
                        <span>₦<span id="subTotal">@Model.SubTotal.ToString("N0")</span></span>
                    </div>
                    
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span style="color: #4caf50;">
                            <i class="fas fa-truck"></i> Free
                        </span>
                    </div>
                    
                    <div class="summary-row">
                        <span>Tax (GST)</span>
                        <span>Included</span>
                    </div>
                    
                    <div class="summary-row">
                        <span>Discount</span>
                        <span style="color: var(--accent);">- ₦0</span>
                    </div>
                    
                    <hr style="margin: 15px 0; border-color: var(--border);">
                    
                    <div class="summary-row total">
                        <span style="font-size: 1.1rem;">Total Amount</span>
                        <span style="font-size: 1.3rem; font-weight: 700; color: var(--accent);">
                            ₦<span id="grandTotal">@Model.SubTotal.ToString("N0")</span>
                        </span>
                    </div>
                    
                    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border);">
                        <div style="display: flex; gap: 15px; margin-bottom: 20px;">
                            <i class="fas fa-credit-card" style="color: var(--accent);"></i>
                            <i class="fab fa-cc-visa" style="color: var(--text-secondary);"></i>
                            <i class="fab fa-cc-mastercard" style="color: var(--text-secondary);"></i>
                            <i class="fab fa-paypal" style="color: var(--text-secondary);"></i>
                        </div>
                        
                        <a href="/Order/Checkout" class="checkout-btn">
                            <i class="fas fa-lock"></i> Proceed to Checkout
                        </a>
                        
                        <a href="/Product/Index" style="display: block; text-align: center; margin-top: 15px; color: var(--text-secondary); text-decoration: none; font-size: 0.9rem;">
                            <i class="fas fa-arrow-left"></i> Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="premium-card empty-cart">
            <div class="empty-cart-icon">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <h3>Your Cart is Empty</h3>
            <p style="color: var(--text-secondary); margin-bottom: 20px;">
                Looks like you haven't added any items to your cart yet.
            </p>
            <a href="/Product/Index" class="shop-now-btn">
                <i class="fas fa-gem"></i> Start Shopping
            </a>
        </div>
    }
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function updateQuantity(itemId, newQuantity) {
    if (newQuantity < 1) return;
        
    $.post('/Cart/UpdateCart', { cartItemId: itemId, quantity: newQuantity })
    .done(function() {
    location.reload();
    })
    .fail(function() {
    alert('Failed to update quantity');
    });
    }
    
    function removeItem(itemId) {
    if (confirm('Are you sure you want to remove this item from your cart?')) {
    $.post('/Cart/RemoveFromCart', { cartItemId: itemId })
    .done(function() {
    location.reload();
    })
    .fail(function() {
    alert('Failed to remove item');
    });
    }
    }
    
    function clearCart() {
    if (confirm('Are you sure you want to clear your entire cart? This action cannot be undone.')) {
    $.post('/Cart/ClearCart')
    .done(function() {
    location.reload();
    })
    .fail(function() {
    alert('Failed to clear cart');
    });
    }
    }
</script>