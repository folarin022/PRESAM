@model PRESAM.Application.DTOs.CheckoutDto

@{
    ViewData["Title"] = "Checkout";
}

<div class="checkout-container">
    <div class="checkout-header">
        <i class="fas fa-gem"></i>
        <h1>Complete Your Order</h1>
        <p>Choose how you want to pay</p>
    </div>

    <div class="checkout-grid">
        <!-- Left Side - Order Summary -->
        <div class="order-summary">
            <h3><i class="fas fa-shopping-bag"></i> Your Order</h3>
            
            <div class="items">
                @foreach (var item in Model.Items)
                {
                    <div class="item">
                        <img src="@item.ProductImage" alt="@item.ProductName" />
                        <div class="item-info">
                            <h4>@item.ProductName</h4>
                            <span>Qty: @item.Quantity</span>
                        </div>
                        <div class="item-price">₦@((item.UnitPrice * item.Quantity).ToString("N0"))</div>
                    </div>
                }
            </div>
            
            <div class="totals">
                <div class="row">
                    <span>Subtotal</span>
                    <span>₦@Model.SubTotal.ToString("N0")</span>
                </div>
                <div class="row">
                    <span>Shipping</span>
                    <span>₦@Model.ShippingFee.ToString("N0")</span>
                </div>
                <div class="row">
                    <span>Tax (7.5%)</span>
                    <span>₦@Model.TaxAmount.ToString("N0")</span>
                </div>
                <div class="row total">
                    <span>Total</span>
                    <span>₦@Model.GrandTotal.ToString("N0")</span>
                </div>
            </div>
        </div>

        <!-- Right Side - Payment Choice -->
        <div class="payment-section">
            <form method="post" asp-action="ProcessBuyNow" asp-controller="Order" id="checkoutForm">
                <!-- Step 1: Choose Payment Type -->
                <div class="step" id="step1">
                    <div class="step-number">1</div>
                    <div class="step-content">
                        <h3>Payment Type</h3>
                        <div class="choice-buttons">
                            <button type="button" class="choice-btn" onclick="selectType('once')">
                                <i class="fas fa-money-bill-wave"></i>
                                <strong>Pay Once</strong>
                                <span>Pay in full today</span>
                            </button>
                            <button type="button" class="choice-btn" onclick="selectType('installment')">
                                <i class="fas fa-calendar-alt"></i>
                                <strong>Pay Installment</strong>
                                <span>Spread payments over time</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Choose Plan (Hidden until installment selected) -->
                <div class="step" id="step2" style="display: none;">
                    <div class="step-number">2</div>
                    <div class="step-content">
                        <h3>Choose Payment Plan</h3>
                        <div class="plan-grid" id="planGrid">
                            <!-- Plans will be shown here -->
                        </div>
                    </div>
                </div>

                <!-- Step 3: Delivery Info -->
                <div class="step" id="step3">
                    <div class="step-number">3</div>
                    <div class="step-content">
                        <h3>Delivery Information</h3>
                        
                        <textarea name="ShippingAddress" class="form-input" placeholder="Enter your complete shipping address" rows="2" required></textarea>
                        
                        <select name="PaymentMethod" class="form-input" required>
                            <option value="">Select payment method</option>
                            <option value="Cash">💵 Cash on Delivery</option>
                            <option value="Card">💳 Credit / Debit Card</option>
                            <option value="Mobile Money">📱 Mobile Money</option>
                            <option value="Transfer">🏦 Bank Transfer</option>
                        </select>
                        
                        <!-- Hidden fields to pass data -->
                        <input type="hidden" name="SelectedPaymentPlan" id="SelectedPaymentPlan" />
                        <input type="hidden" name="SubTotal" value="@Model.SubTotal" />
                        <input type="hidden" name="ShippingFee" value="@Model.ShippingFee" />
                        <input type="hidden" name="TaxAmount" value="@Model.TaxAmount" />
                        <input type="hidden" name="GrandTotal" id="GrandTotal" value="@Model.GrandTotal" />
                        
                        <!-- Pass items as hidden fields -->
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <input type="hidden" name="Items[@i].ProductId" value="@Model.Items[i].ProductId" />
                            <input type="hidden" name="Items[@i].ProductName" value="@Model.Items[i].ProductName" />
                            <input type="hidden" name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice" />
                            <input type="hidden" name="Items[@i].Quantity" value="@Model.Items[i].Quantity" />
                            <input type="hidden" name="Items[@i].ProductImage" value="@Model.Items[i].ProductImage" />
                        }
                        
                        <button type="submit" class="place-order-btn" id="placeOrderBtn">
                            <i class="fas fa-check-circle"></i> Place Order
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .checkout-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 30px 20px;
    }
    
    .checkout-header {
        text-align: center;
        margin-bottom: 40px;
    }
    
    .checkout-header i {
        font-size: 50px;
        color: var(--accent);
        margin-bottom: 10px;
    }
    
    .checkout-header h1 {
        font-size: 28px;
        margin-bottom: 8px;
    }
    
    .checkout-header p {
        color: var(--text-secondary);
    }
    
    .checkout-grid {
        display: grid;
        grid-template-columns: 1fr 1.3fr;
        gap: 35px;
    }
    
    .order-summary {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 25px;
        border: 1px solid var(--border);
        height: fit-content;
        position: sticky;
        top: 100px;
    }
    
    .order-summary h3 {
        font-size: 18px;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--border);
    }
    
    .items {
        margin-bottom: 20px;
        max-height: 300px;
        overflow-y: auto;
    }
    
    .item {
        display: flex;
        gap: 15px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }
    
    .item img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 12px;
    }
    
    .item-info {
        flex: 1;
    }
    
    .item-info h4 {
        font-size: 14px;
        margin-bottom: 5px;
    }
    
    .item-info span {
        font-size: 12px;
        color: var(--text-secondary);
    }
    
    .item-price {
        font-weight: bold;
        color: var(--accent);
    }
    
    .totals {
        border-top: 1px solid var(--border);
        padding-top: 15px;
    }
    
    .row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 14px;
    }
    
    .row.total {
        font-weight: bold;
        font-size: 18px;
        border-top: 2px solid var(--accent);
        margin-top: 8px;
        padding-top: 12px;
        color: var(--accent);
    }
    
    .payment-section {
        background: var(--bg-card);
        border-radius: 24px;
        padding: 25px;
        border: 1px solid var(--border);
    }
    
    .step {
        display: flex;
        gap: 18px;
        margin-bottom: 30px;
        padding-bottom: 25px;
        border-bottom: 1px solid var(--border);
    }
    
    .step:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }
    
    .step-number {
        width: 40px;
        height: 40px;
        background: var(--accent);
        color: black;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 18px;
        flex-shrink: 0;
    }
    
    .step-content {
        flex: 1;
    }
    
    .step-content h3 {
        font-size: 18px;
        margin-bottom: 15px;
    }
    
    .choice-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }
    
    .choice-btn {
        background: var(--bg-primary);
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
    }
    
    .choice-btn:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
    }
    
    .choice-btn i {
        font-size: 32px;
        color: var(--accent);
        margin-bottom: 10px;
        display: block;
    }
    
    .choice-btn strong {
        display: block;
        font-size: 16px;
        margin-bottom: 5px;
    }
    
    .choice-btn span {
        font-size: 12px;
        color: var(--text-secondary);
    }
    
    .plan-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 350px;
        overflow-y: auto;
    }
    
    .plan-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        background: var(--bg-primary);
        border: 2px solid var(--border);
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .plan-card:hover {
        border-color: var(--accent);
    }
    
    .plan-card.selected {
        border-color: var(--accent);
        background: rgba(198, 164, 63, 0.1);
    }
    
    .plan-info h4 {
        font-size: 15px;
        margin-bottom: 5px;
    }
    
    .plan-interest {
        font-size: 12px;
        color: var(--accent);
    }
    
    .plan-amount {
        text-align: right;
    }
    
    .plan-price {
        font-size: 20px;
        font-weight: bold;
        color: var(--accent);
    }
    
    .plan-total {
        font-size: 11px;
        color: var(--text-secondary);
    }
    
    .form-input {
        width: 100%;
        padding: 14px;
        margin-bottom: 15px;
        background: var(--bg-primary);
        border: 1px solid var(--border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: inherit;
    }
    
    .form-input:focus {
        outline: none;
        border-color: var(--accent);
    }
    
    .place-order-btn {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
        color: black;
        font-weight: bold;
        font-size: 16px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 10px;
    }
    
    .place-order-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(198, 164, 63, 0.3);
    }
    
    @@media (max-width: 900px) {
        .checkout-grid {
            grid-template-columns: 1fr;
        }
        .order-summary {
            position: static;
        }
    }
</style>

<script>
    let selectedType = null;
    
    const plans = @Html.Raw(Json.Serialize(Model.PaymentOptions.Where(p => p.PlanType != "FullPayment").Select(p => new {
        planType = p.PlanType,
        description = p.Description,
        interestRate = p.InterestRate,
        installmentAmount = p.InstallmentAmount,
        totalAmount = p.TotalAmount,
        duration = p.Duration
    })));
    
    function selectType(type) {
        selectedType = type;
        const step2 = document.getElementById('step2');
        const selectedPlanInput = document.getElementById('SelectedPaymentPlan');
        const grandTotalInput = document.getElementById('GrandTotal');
        
        if (type === 'once') {
            step2.style.display = 'none';
            selectedPlanInput.value = 'FullPayment';
            grandTotalInput.value = @Model.GrandTotal;
        } else {
            step2.style.display = 'flex';
            loadPlans();
        }
        
        // Highlight selected button
        document.querySelectorAll('.choice-btn').forEach(btn => {
            btn.style.borderColor = 'var(--border)';
            btn.style.background = 'var(--bg-primary)';
        });
        event.currentTarget.style.borderColor = 'var(--accent)';
        event.currentTarget.style.background = 'rgba(198, 164, 63, 0.1)';
    }
    
    function loadPlans() {
        const grid = document.getElementById('planGrid');
        grid.innerHTML = '';
        
        plans.forEach(plan => {
            const card = document.createElement('div');
            card.className = 'plan-card';
            card.setAttribute('data-plan', plan.planType);
            card.setAttribute('data-total', plan.totalAmount);
            card.setAttribute('data-installment', plan.installmentAmount);
            card.onclick = () => selectPlan(card, plan.planType, plan.totalAmount);
            
            card.innerHTML = `
                <div class="plan-info">
                    <h4>${plan.description}</h4>
                    <span class="plan-interest">+${plan.interestRate}% interest</span>
                </div>
                <div class="plan-amount">
                    <div class="plan-price">₦${plan.installmentAmount.toLocaleString()}</div>
                    <div class="plan-total">Total: ₦${plan.totalAmount.toLocaleString()} · ${plan.duration} payments</div>
                </div>
            `;
            grid.appendChild(card);
        });
    }
    
    function selectPlan(card, planType, totalAmount) {
        document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        
        document.getElementById('SelectedPaymentPlan').value = planType;
        document.getElementById('GrandTotal').value = totalAmount;
    }
</script>