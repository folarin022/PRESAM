@model IEnumerable<PRESAM.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Categories";
}
<div class="container">
    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
        <h2>Categories</h2>
        @if (User.IsInRole("Admin")) { <a href="/Category/Create" class="btn-premium">+ New Category</a> }
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px;">
        @foreach (var cat in Model)
        {
            <div class="premium-card" style="text-align: center;">
                <i class="fas fa-folder-open" style="font-size: 40px; color: var(--accent); margin-bottom: 15px;"></i>
                <h3>@cat.Name</h3>
                <p style="color: var(--text-secondary);">@cat.ProductCount products</p>
                <a href="/Product/ByCategory/@cat.Id" class="btn-premium" style="display: inline-block; margin-top: 15px;">Browse</a>
                @if (User.IsInRole("Admin"))
                {
                    <div style="margin-top: 15px;">
                        <a href="/Category/Edit/@cat.Id" class="btn-premium" style="padding: 5px 15px;">Edit</a>
                        <button onclick="deleteCategory('@cat.Id')" class="btn-premium" style="background: var(--danger); padding: 5px 15px;">Delete</button>
                    </div>
                }
            </div>
        }
    </div>
</div>
<script>
    function deleteCategory(id) { if(confirm('Delete category?')) $.post('/Category/Delete', { id: id }).done(function(){ location.reload(); }); }
</script>