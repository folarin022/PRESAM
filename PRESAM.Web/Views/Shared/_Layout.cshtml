<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRESAM</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #111111;
            --bg-card: #1a1a1a;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --accent: #c6a43f;
            --accent-hover: #d4b856;
            --border: #2a2a2a;
            --danger: #e74c3c;
        }
        [data-theme="light"] {
            --bg-primary: #ffffff;
            --bg-secondary: #f5f7fb;
            --bg-card: #ffffff;
            --text-primary: #1a1a2e;
            --text-secondary: #666666;
            --accent: #2d6a4f;
            --accent-hover: #1b4d3e;
            --border: #e0e0e0;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            transition: all 0.3s ease;
        }

        /* Navbar */
        .navbar {
            background: var(--bg-secondary);
            padding: 16px 30px;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Logo */
        .logo {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
        }
        .logo span {
            color: var(--accent);
            font-weight: 800;
        }
        .logo i {
            margin-right: 6px;
            color: var(--accent);
        }

        /* Hamburger Menu Button (Hidden on desktop) */
        .menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--text-primary);
            font-size: 24px;
            cursor: pointer;
            padding: 8px;
        }

        /* Navigation Links */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 32px;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s;
        }
        .nav-links a:hover {
            color: var(--accent);
        }

        /* Right side items */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        /* Theme Toggle */
        .theme-toggle {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 6px 14px;
            cursor: pointer;
        }
        .theme-toggle:hover {
            border-color: var(--accent);
        }

        /* Auth Buttons */
        .btn-login {
            border: 1px solid var(--accent);
            color: var(--accent) !important;
            padding: 8px 22px;
            border-radius: 40px;
        }
        .btn-login:hover {
            background: var(--accent);
            color: white !important;
        }
        .btn-register {
            background: var(--accent);
            color: white !important;
            padding: 8px 22px;
            border-radius: 40px;
        }
        .logout-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .logout-btn:hover {
            color: var(--danger);
        }

        /* Cart Icon */
        .cart-icon {
            position: relative;
        }
        .cart-badge {
            position: absolute;
            top: -8px;
            right: -12px;
            background: var(--accent);
            color: black;
            font-size: 9px;
            padding: 2px 5px;
            border-radius: 50%;
        }

        /* Mobile Menu (Hidden by default) */
        .mobile-menu {
            display: none;
            flex-direction: column;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--border);
        }
        .mobile-menu a, .mobile-menu form {
            padding: 12px 0;
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 16px;
        }
        .mobile-menu a:hover {
            color: var(--accent);
        }
        .mobile-menu .logout-btn {
            padding: 12px 0;
            width: 100%;
            text-align: left;
        }

        /* Main Content */
        main {
            min-height: calc(100vh - 200px);
            padding: 40px 0;
        }

        /* Container */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 30px;
        }

        /* Footer */
        .footer {
            background: var(--bg-secondary);
            padding: 50px 40px 30px;
            border-top: 1px solid var(--border);
            margin-top: 60px;
        }
        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 40px;
        }
        .footer-section h4 {
            color: var(--accent);
            margin-bottom: 16px;
            font-size: 16px;
        }
        .footer-section p, .footer-section a {
            color: var(--text-secondary);
            text-decoration: none;
            line-height: 1.8;
            font-size: 13px;
        }
        .copyright {
            text-align: center;
            padding-top: 40px;
            margin-top: 40px;
            border-top: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 12px;
        }

        /* Premium Card */
        .premium-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }
        .premium-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent);
        }

        /* Buttons */
        .btn-premium {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
        }

        /* Responsive - Show hamburger on tablet/mobile */
        @@media (max-width: 900px) {
            .navbar {
                padding: 12px 20px;
            }
            
            /* Hide desktop nav links and right items on mobile */
            .nav-links {
                display: none;
            }
            .nav-right {
                display: none;
            }
            
            /* Show hamburger button */
            .menu-btn {
                display: block;
            }
            
            /* Show mobile menu when active */
            .mobile-menu.active {
                display: flex;
            }
            
            .container {
                padding: 0 20px;
            }
        }
        
        /* Desktop: hide mobile menu */
        @@media (min-width: 901px) {
            .mobile-menu {
                display: none !important;
            }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="navbar-container">
            <!-- Logo -->
            <a href="/" class="logo">
                <i class="fas fa-gem"></i> PRE<span>SAM</span>
            </a>

            <!-- Desktop Navigation Links -->
            <div class="nav-links">
                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/">Home</a>
                    <a href="/Product/Index">Shop</a>
                    <a href="/Cart/Index" class="cart-icon">
                        Cart <span class="cart-badge" id="cartCount" style="display:none;">0</span>
                    </a>
                    <a href="/Order/MyOrders">Orders</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Dashboard">Admin</a>
                    }
                }
                else
                {
                    <a href="/">Home</a>
                    <a href="/Product/Index">Shop</a>
                }
            </div>

            <!-- Desktop Right Side -->
            <div class="nav-right">
                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="logout-btn">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="btn-login">Sign In</a>
                    <a href="/Account/Register" class="btn-register">Join</a>
                }
                
                <div class="theme-toggle" onclick="toggleTheme()">
                    <i class="fas fa-moon" id="themeIcon"></i>
                </div>
            </div>

            <!-- Hamburger Menu Button (Mobile only) -->
            <button class="menu-btn" onclick="toggleMobileMenu()">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <!-- Mobile Menu (Hidden by default) -->
        <div class="mobile-menu" id="mobileMenu">
            @if (User.Identity.IsAuthenticated)
            {
                <a href="/">Home</a>
                <a href="/Product/Index">Shop</a>
                <a href="/Cart/Index">Cart</a>
                <a href="/Order/MyOrders">Orders</a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard">Admin</a>
                }
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="logout-btn">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            }
            else
            {
                <a href="/">Home</a>
                <a href="/Product/Index">Shop</a>
                <a href="/Account/Login">Sign In</a>
                <a href="/Account/Register">Join Now</a>
            }
            
            <div class="theme-toggle" onclick="toggleTheme(); toggleMobileMenu();">
                <i class="fas fa-moon"></i> Dark/Light
            </div>
        </div>
    </nav>

    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4><i class="fas fa-gem"></i> PRESAM</h4>
                <p>Premium shopping experience</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <p><a href="/">Home</a></p>
                <p><a href="/Product/Index">Shop</a></p>
                <p><a href="/Order/MyOrders">Orders</a></p>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <p><a href="#">FAQ</a></p>
                <p><a href="#">Contact</a></p>
            </div>
            <div class="footer-section">
                <h4>Contact</h4>
                <p><i class="fas fa-envelope"></i> support@presam.com</p>
            </div>
        </div>
        <div class="copyright">
            <p>&copy; 2025 PRESAM. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function toggleMobileMenu() {
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('active');
        }

        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            const newTheme = current === 'light' ? 'dark' : 'light';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            const icon = document.getElementById('themeIcon');
            if (newTheme === 'light') {
                icon.className = 'fas fa-sun';
            } else {
                icon.className = 'fas fa-moon';
            }
        }

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
            const icon = document.getElementById('themeIcon');
            if (savedTheme === 'light') {
                icon.className = 'fas fa-sun';
            } else {
                icon.className = 'fas fa-moon';
            }
        }

        function updateCartCount() {
            @if (User.Identity.IsAuthenticated)
            {
                <text>
                $.get('/Cart/GetCartCount', function(data) {
                    if (data > 0) {
                        $('.cart-badge').text(data).show();
                    } else {
                        $('.cart-badge').hide();
                    }
                });
                </text>
            }
        }

        $(document).ready(function() {
            updateCartCount();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>