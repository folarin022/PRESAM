@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PRESAM</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

    <style>
            :root {
                --bg-primary: #0a0a0a;
                --bg-secondary: #111111;
                --bg-card: #1a1a1a;
                --text-primary: #ffffff;
                --text-secondary: #a0a0a0;
                --accent: #c6a43f;
                --accent-hover: #d4b856;
                --border: #2a2a2a;
                --danger: #e74c3c;
            }

            [data-theme="light"] {
                --bg-primary: #ffffff;
                --bg-secondary: #f5f7fb;
                --bg-card: #ffffff;
                --text-primary: #1a1a2e;
                --text-secondary: #666666;
                --accent: #2d6a4f;
                --accent-hover: #1b4d3e;
                --border: #e0e0e0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Plus Jakarta Sans', sans-serif;
                background: var(--bg-primary);
                color: var(--text-primary);
                transition: all 0.3s ease;
            }

            /* Navbar */
            .navbar {
                background: var(--bg-secondary);
                padding: 16px 40px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid var(--border);
                position: sticky;
                top: 0;
                z-index: 1000;
                flex-wrap: wrap;
            }

            .logo {
                font-size: 24px;
                font-weight: 700;
                color: var(--text-primary);
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 2px;
            }

                .logo span {
                    color: var(--accent);
                    font-weight: 800;
                }

                .logo i {
                    font-size: 28px;
                    color: var(--accent);
                }

            /* Navigation Links with Icons */
            .nav-links {
                display: flex;
                align-items: center;
                gap: 28px;
                flex-wrap: wrap;
            }

                .nav-links a {
                    text-decoration: none;
                    color: var(--text-secondary);
                    font-weight: 500;
                    font-size: 14px;
                    transition: all 0.2s;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                    .nav-links a i {
                        font-size: 16px;
                        transition: all 0.2s;
                    }

                    .nav-links a:hover {
                        color: var(--accent);
                    }

                        .nav-links a:hover i {
                            transform: translateY(-2px);
                        }

            /* User Profile Section */
            .user-section {
                display: flex;
                align-items: center;
                gap: 20px;
            }

            .user-profile {
                display: flex;
                align-items: center;
                gap: 10px;
                cursor: pointer;
                padding: 8px 12px;
                border-radius: 40px;
                background: var(--bg-primary);
                border: 1px solid var(--border);
                transition: all 0.2s;
            }

                .user-profile:hover {
                    border-color: var(--accent);
                }

            .user-avatar {
                width: 32px;
                height: 32px;
                background: var(--accent);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: black;
                font-weight: bold;
            }

            .user-name {
                font-size: 14px;
                font-weight: 500;
                color: var(--text-primary);
            }

            .user-dropdown {
                position: relative;
            }

            .dropdown-menu {
                position: absolute;
                top: 50px;
                right: 0;
                background: var(--bg-card);
                border: 1px solid var(--border);
                border-radius: 16px;
                padding: 10px 0;
                min-width: 200px;
                display: none;
                z-index: 1001;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            }

                .dropdown-menu.show {
                    display: block;
                    animation: fadeIn 0.2s ease;
                }

            @@keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(-10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .dropdown-menu a,
            .dropdown-menu button {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 12px 20px;
                text-decoration: none;
                color: var(--text-secondary);
                font-size: 14px;
                width: 100%;
                border: none;
                background: none;
                cursor: pointer;
                font-family: inherit;
            }

                .dropdown-menu a:hover,
                .dropdown-menu button:hover {
                    background: var(--bg-primary);
                    color: var(--accent);
                }

            .dropdown-divider {
                height: 1px;
                background: var(--border);
                margin: 8px 0;
            }

            .user-email {
                font-size: 12px;
                color: var(--text-secondary);
                padding: 8px 20px;
                border-bottom: 1px solid var(--border);
            }

            /* Theme Toggle */
            .theme-toggle {
                background: var(--bg-card);
                border: 1px solid var(--border);
                border-radius: 40px;
                padding: 8px 14px;
                cursor: pointer;
            }

            /* Main Content */
            main {
                min-height: calc(100vh - 200px);
                padding: 40px 0;
            }

            /* Container */
            .container {
                max-width: 1280px;
                margin: 0 auto;
                padding: 0 30px;
            }

            /* Footer */
            .footer {
                background: var(--bg-secondary);
                padding: 50px 40px 30px;
                border-top: 1px solid var(--border);
                margin-top: 60px;
            }

            .footer-content {
                max-width: 1200px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 40px;
            }

            .footer-section h4 {
                color: var(--accent);
                margin-bottom: 16px;
                font-size: 16px;
            }

            .footer-section p,
            .footer-section a {
                color: var(--text-secondary);
                text-decoration: none;
                line-height: 1.8;
                font-size: 13px;
            }

            .copyright {
                text-align: center;
                padding-top: 40px;
                margin-top: 40px;
                border-top: 1px solid var(--border);
                color: var(--text-secondary);
                font-size: 12px;
            }

            /* Cart Badge */
            .cart-icon {
                position: relative;
            }

            .cart-badge {
                position: absolute;
                top: -8px;
                right: -12px;
                background: var(--accent);
                color: black;
                font-size: 10px;
                font-weight: 700;
                padding: 2px 6px;
                border-radius: 50%;
            }

            @@media (max-width: 900px) {
                .navbar {
                    padding: 15px 20px;
                    flex-direction: column;
                    gap: 15px;
                }

                .nav-links {
                    justify-content: center;
                    gap: 20px;
                }

                .user-section {
                    margin-top: 10px;
                }
            }
    </style>
</head>

<body>
    @{
        var user = User.Identity.IsAuthenticated ? await _userManager.GetUserAsync(User) : null;
        var userName = user != null ? $"{user.FirstName} {user.LastName}" : "";
        var userInitial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";
    }

    <nav class="navbar">
        <a href="/Home/Index" class="logo">
            <i class="fas fa-gem"></i>PRE<span>SAM</span>
        </a>

        <div class="nav-links">
            <a href="/Home/Index">
                <i class="fas fa-home"></i> Home
            </a>
            <a href="/Product/Index">
                <i class="fas fa-store"></i> Shop
            </a>

            @if (User.Identity.IsAuthenticated)
            {
                <a href="/Cart/Index" class="cart-icon">
                    <i class="fas fa-shopping-bag"></i> Cart
                    <span class="cart-badge" id="cartCount" style="display:none;">0</span>
                </a>
                <a href="/Order/MyOrders">
                    <i class="fas fa-list"></i> My Orders
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard">
                        <i class="fas fa-chart-line"></i> Admin
                    </a>
                }
            }
        </div>

        <div class="user-section">
            @if (User.Identity.IsAuthenticated)
            {
                <div class="user-dropdown">
                    <div class="user-profile" onclick="toggleDropdown()">
                        <div class="user-avatar">@userInitial</div>
                        <span class="user-name">@userName</span>
                        <i class="fas fa-chevron-down" style="font-size: 12px;"></i>
                    </div>

                    <div class="dropdown-menu" id="userDropdown">
                        <div class="user-email">@user?.Email</div>
                        <div class="dropdown-divider"></div>
                        <a href="/Order/MyOrders"><i class="fas fa-list"></i> My Orders</a>
                        <a href="/Cart/Index"><i class="fas fa-shopping-bag"></i> My Cart</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/Admin/Dashboard"><i class="fas fa-chart-line"></i> Admin Panel</a>
                        }

                        <div class="dropdown-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a href="/Account/Login" style="padding: 8px 20px; background: var(--accent); border-radius: 40px; color: black; text-decoration: none; font-weight: 500; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </a>
                <a href="/Account/Register" style="padding: 8px 20px; border: 1px solid var(--accent); border-radius: 40px; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-user-plus"></i> Join
                </a>
            }

            <div class="theme-toggle" onclick="toggleTheme()">
                <i class="fas fa-moon" id="themeIcon"></i>
            </div>
        </div>
    </nav>

    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4><i class="fas fa-gem"></i> PRESAM</h4>
                <p>Premium shopping experience</p>
            </div>

            <div class="footer-section">
                <h4>Quick Links</h4>
                <p><a href="/Home/Index"><i class="fas fa-home"></i> Home</a></p>
                <p><a href="/Product/Index"><i class="fas fa-store"></i> Shop</a></p>
                <p><a href="/Cart/Index"><i class="fas fa-shopping-bag"></i> Cart</a></p>
                <p><a href="/Order/MyOrders"><i class="fas fa-list"></i> Orders</a></p>
            </div>

            <div class="footer-section">
                <h4>Support</h4>
                <p><a href="#"><i class="fas fa-question-circle"></i> FAQ</a></p>
                <p><a href="#"><i class="fas fa-envelope"></i> Contact Us</a></p>
                <p><a href="#"><i class="fas fa-shield-alt"></i> Privacy Policy</a></p>
            </div>

            <div class="footer-section">
                <h4>Contact</h4>
                <p><i class="fas fa-envelope"></i> support@presam.com</p>
                <p><i class="fas fa-phone"></i> +234 123 456 7890</p>
            </div>
        </div>

        <div class="copyright">
            <p>&copy; 2025 PRESAM. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function toggleDropdown() {
        document.getElementById('userDropdown').classList.toggle('show');
        }

        function toggleTheme() {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const newTheme = current === 'light' ? 'dark' : 'light';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        const icon = document.getElementById('themeIcon');

        if (newTheme === 'light') {
        icon.className = 'fas fa-sun';
        }
        else {
        icon.className = 'fas fa-moon';
        }
        }

        // Close dropdown when clicking outside
        window.onclick = function (event) {
        if (!event.target.closest('.user-dropdown')) {
        document.getElementById('userDropdown').classList.remove('show');
        }
        };

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
        const icon = document.getElementById('themeIcon');

        if (savedTheme === 'light') {
        icon.className = 'fas fa-sun';
        }
        else {
        icon.className = 'fas fa-moon';
        }
        }

        function updateCartCount() {
        @if (User.Identity.IsAuthenticated)
        {
            <text>
                $.get('/Cart/GetCartCount', function (data) {
                if (data > 0) {
                $('#cartCount').text(data).show();
                }
                else {
                $('#cartCount').hide();
                }
                });
            </text>
        }
        }

        $(document).ready(function () {
        updateCartCount();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>