@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="en" data-theme="dark">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - PRESAM</title>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

        <style>
            :root {
                --bg-primary: #0a0a0a;
                --bg-secondary: #111111;
                --bg-card: #1a1a1a;
                --text-primary: #ffffff;
                --text-secondary: #a0a0a0;
                --accent: #c6a43f;
                --accent-hover: #d4b856;
                --border: #2a2a2a;
                --danger: #e74c3c;
            }

            [data-theme="light"] {
                --bg-primary: #ffffff;
                --bg-secondary: #f5f7fb;
                --bg-card: #ffffff;
                --text-primary: #1a1a2e;
                --text-secondary: #666666;
                --accent: #2d6a4f;
                --accent-hover: #1b4d3e;
                --border: #e0e0e0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Plus Jakarta Sans', sans-serif;
                background: var(--bg-primary);
                color: var(--text-primary);
                transition: all 0.3s ease;
            }

            /* Navbar */
            .navbar {
            z-index: 1000;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .hamburger {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 24px;
            color: var(--text-primary);
            padding: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            text-decoration: none;
        }
        .logo span { color: var(--accent); font-weight: 800; }
        .logo i { margin-right: 6px; color: var(--accent); }

        /* Right side icons */
        .navbar-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .theme-toggle {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 8px 14px;
            cursor: pointer;
        }

        /* Left Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: -100%;
            width: var(--sidebar-width);
            height: 100%;
            background: var(--bg-secondary);
            z-index: 2000;
            transition: 0.3s ease;
            box-shadow: 5px 0 30px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border);
        }

        .sidebar.open {
            left: 0;
        }

        .sidebar-header {
            padding: 20px 25px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-header h3 {
            font-size: 18px;
        }

        .close-sidebar {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: var(--text-secondary);
        }

        /* User Profile */
        .sidebar-user {
            padding: 25px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-avatar {
            width: 70px;
            height: 70px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 32px;
            font-weight: bold;
            color: black;
        }

        .sidebar-user h4 {
            font-size: 16px;
            margin-bottom: 4px;
        }

        .sidebar-user p {
            font-size: 12px;
            color: var(--text-secondary);
        }

        /* Navigation Links */
        .sidebar-nav {
            flex: 1;
            padding: 15px 0;
            overflow-y: auto;
        }

        .sidebar-nav a, .sidebar-nav button {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 25px;
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 14px;
            transition: all 0.2s;
            width: 100%;
            background: none;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }

        .sidebar-nav a:hover, .sidebar-nav button:hover {
            background: var(--bg-primary);
            color: var(--accent);
        }

        .sidebar-nav a.active {
            background: var(--bg-primary);
            color: var(--accent);
            border-right: 3px solid var(--accent);
        }

        .sidebar-nav i {
            width: 22px;
            font-size: 16px;
        }

        .sidebar-divider {
            height: 1px;
            background: var(--border);
            margin: 12px 20px;
        }

        .sidebar-footer {
            padding: 20px;
            border-top: 1px solid var(--border);
            font-size: 11px;
            color: var(--text-secondary);
            text-align: center;
        }

        /* Overlay */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }

        .overlay.show {
            display: block;
        }

        /* Top Bar with Search and Actions */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .search-box {
            display: flex;
            align-items: center;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 50px;
            padding: 8px 20px;
            flex: 1;
            max-width: 400px;
        }

        .search-box input {
            background: none;
            border: none;
            color: var(--text-primary);
            padding: 10px;
            flex: 1;
            outline: none;
        }

        .search-box button {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
        }

        .action-btn {
            background: var(--accent);
            border: none;
            padding: 10px 20px;
            border-radius: 40px;
            color: black;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        /* Main Content */
        main {
            min-height: calc(100vh - 200px);
            padding: 30px 0;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 30px;
        }

        /* Footer */
        .footer {
            background: var(--bg-secondary);
            padding: 40px 40px 20px;
            border-top: 1px solid var(--border);
            margin-top: 50px;
        }
        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 40px;
        }
        .footer-section h4 {
            color: var(--accent);
            margin-bottom: 15px;
            font-size: 14px;
        }
        .footer-section p, .footer-section a {
            color: var(--text-secondary);
            text-decoration: none;
            line-height: 1.8;
            font-size: 13px;
        }
        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 30px;
            margin-top: 30px;
            border-top: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 12px;
            flex-wrap: wrap;
            gap: 15px;
        }
        .datetime {
            display: flex;
            gap: 15px;
        }

        @@media (max-width: 768px) {
            .navbar { padding: 15px 20px; }
            .container { padding: 0 20px; }
            .top-bar { flex-direction: column; align-items: stretch; }
            .search-box { max-width: 100%; }
            .footer-bottom { flex-direction: column; text-align: center; }
        }

        .hero {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
            border-radius: 30px;
            padding: 60px 40px;
            text-align: center;
            margin-bottom: 50px;
            color: black;
        }
        .hero h1 {
            font-size: 48px;
            margin-bottom: 15px;
        }
        .hero p {
            font-size: 18px;
            opacity: 0.9;
        }

        /* Categories */
        .section-title {
            font-size: 24px;
            margin-bottom: 25px;
        }
        .categories-grid {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 50px;
        }
        .category-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 15px 25px;
            text-decoration: none;
            color: var(--text-primary);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .category-card:hover {
            border-color: var(--accent);
            transform: translateY(-3px);
        }
        .category-card i {
            font-size: 24px;
            color: var(--accent);
        }
        .category-card span {
            font-size: 14px;
        }
        .category-card small {
            color: var(--text-secondary);
        }
    </style>
</head>
<body>

    @{
        var user = User.Identity.IsAuthenticated ? await _userManager.GetUserAsync(User) : null;
        var userName = user != null ? $"{user.FirstName} {user.LastName}" : "";
        var userInitial = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";
        var userEmail = user?.Email ?? "";
        string currentPath = Context.Request.Path.ToString();
        
        bool IsActive(string path) => currentPath.StartsWith(path);
    }

    <!-- Top Navbar - Hamburger on LEFT side -->
    <nav class="navbar">
        <div class="navbar-left">
            <button class="hamburger" onclick="openSidebar()">
                <i class="fas fa-bars"></i>
            </button>
            <a href="/" class="logo">
                <i class="fas fa-gem"></i> PRE<span>SAM</span>
            </a>
        </div>
        
        <div class="navbar-right">
            <div class="theme-toggle" onclick="toggleTheme()">
                <i class="fas fa-moon" id="themeIcon"></i>
            </div>
        </div>
    </nav>

    <!-- Overlay -->
    <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

    <!-- Left Sidebar Menu -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h3><i class="fas fa-gem" style="color: var(--accent);"></i> PRESAM</h3>
            <button class="close-sidebar" onclick="closeSidebar()">&times;</button>
        </div>

        <div class="sidebar-user">
            <div class="sidebar-avatar">@userInitial</div>
            <h4>@(User.Identity.IsAuthenticated ? userName : "Guest")</h4>
            <p>@(User.Identity.IsAuthenticated ? userEmail : "Welcome to PRESAM")</p>
        </div>

        <div class="sidebar-nav">
            <a href="/Home/Index" onclick="closeSidebar()" class="@(IsActive("/Home/Index") ? "active" : "")">
                <i class="fas fa-home"></i> Home
            </a>
            <a href="/Product/Index" onclick="closeSidebar()" class="@(IsActive("/Product") ? "active" : "")">
                <i class="fas fa-store"></i> Shop
            </a>
            
            @if (User.Identity.IsAuthenticated)
            {
                <a href="/Cart/Index" onclick="closeSidebar()" class="@(IsActive("/Cart") ? "active" : "")">
                    <i class="fas fa-shopping-bag"></i> Cart
                </a>
                <a href="/Order/MyOrders" onclick="closeSidebar()" class="@(IsActive("/Order") ? "active" : "")">
                    <i class="fas fa-list"></i> My Orders
                </a>
                
                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-divider"></div>
                    <a href="/Admin/Dashboard" onclick="closeSidebar()" class="@(IsActive("/Admin/Dashboard") ? "active" : "")">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>
                    <a href="/Admin/Orders" onclick="closeSidebar()" class="@(IsActive("/Admin/Orders") ? "active" : "")">
                        <i class="fas fa-truck"></i> Manage Orders
                    </a>
                    <a href="/Admin/Users" onclick="closeSidebar()" class="@(IsActive("/Admin/Users") ? "active" : "")">
                        <i class="fas fa-users"></i> Manage Users
                    </a>
                }
                
                <div class="sidebar-divider"></div>
                
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" onclick="closeSidebar()">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </button>
                </form>
            }
            else
            {
                <div class="sidebar-divider"></div>
                <a href="/Account/Login" onclick="closeSidebar()">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </a>
                <a href="/Account/Register" onclick="closeSidebar()">
                    <i class="fas fa-user-plus"></i> Join Now
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <p>PRESAM</p>
            <p>Premium Shopping Experience</p>
            <p>Version 1.0</p>
        </div>
    </div>

    <!-- Main Content -->
    <main>
        <div class="container">
            <!-- Top Search Bar and Action Buttons -->
            <div class="top-bar">
                <div class="search-box">
                    <input type="text" id="searchInput" placeholder="Search products..." onkeypress="if(event.key==='Enter') searchProducts()">
                    <button onclick="searchProducts()"><i class="fas fa-search"></i></button>
                </div>
            </div>

            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>PRESAM</h4>
                <p>Premium shopping experience</p>
                <p>Quality products, best prices</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <p><a href="/">Home</a></p>
                <p><a href="/Product/Index">Shop</a></p>
                <p><a href="/Cart/Index">Cart</a></p>
                <p><a href="/Order/MyOrders">Orders</a></p>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <p><a href="#">FAQ</a></p>
                <p><a href="#">Contact Us</a></p>
                <p><a href="#">Privacy Policy</a></p>
            </div>
            <div class="footer-section">
                <h4>Contact</h4>
                <p><i class="fas fa-envelope"></i> support@presam.com</p>
                <p><i class="fas fa-phone"></i> +234 123 456 7890</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 PRESAM. All rights reserved.</p>
            <div class="datetime">
                <span id="temperature">🌡️ 32°C</span>
                <span id="language">🌐 ENG</span>
                <span id="time"></span>
                <span id="date"></span>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Sidebar functions
        function openSidebar() {
            document.getElementById('sidebar').classList.add('open');
            document.getElementById('overlay').classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('overlay').classList.remove('show');
            document.body.style.overflow = '';
        }

        // Theme toggle
        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            const newTheme = current === 'light' ? 'dark' : 'light';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            const icon = document.getElementById('themeIcon');
            icon.className = newTheme === 'light' ? 'fas fa-sun' : 'fas fa-moon';
        }

        // Search function
        function searchProducts() {
            const searchTerm = document.getElementById('searchInput').value;
            if (searchTerm.trim()) {
                window.location.href = '/Product/Search?searchTerm=' + encodeURIComponent(searchTerm);
            }
        }

        // Update date and time
        function updateDateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            const dateStr = now.toLocaleDateString('en-US', { month: 'numeric', day: 'numeric', year: 'numeric' });
            document.getElementById('time').innerHTML = `<i class="far fa-clock"></i> ${timeStr}`;
            document.getElementById('date').innerHTML = `<i class="far fa-calendar-alt"></i> ${dateStr}`;
        }

        // Cart count update
        function updateCartCount() {
            @if (User.Identity.IsAuthenticated)
            {
                <text>
                $.get('/Cart/GetCartCount', function(data) {
                    if (data > 0) {
                        $('#cartCount').text(data).show();
                    } else {
                        $('#cartCount').hide();
                    }
                });
                </text>
            }
        }

        // Initialize
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
            const icon = document.getElementById('themeIcon');
            if (savedTheme === 'light') icon.className = 'fas fa-sun';
            else icon.className = 'fas fa-moon';
        }

        updateDateTime();
        setInterval(updateDateTime, 1000);
        
        $(document).ready(function() {
            updateCartCount();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>